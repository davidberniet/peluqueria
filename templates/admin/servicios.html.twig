{% extends 'base.html.twig' %}

{% block title %}Gestionar Servicios | Admin Venus{% endblock %}

{% block body %}
	<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
		<div>
			<h1 class="text-3xl font-extrabold text-gray-900">Catálogo de Servicios</h1>
			<p class="text-gray-500 mt-1">Añade, edita o elimina lo que ofreces.</p>
		</div>
		<div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
			<a href="{{ path('app_admin_dashboard') }}" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-xl transition-colors text-center">
				&larr; Volver al Panel
			</a>
			<a href="{{ path('app_admin_servicio_nuevo') }}" class="bg-pink-600 hover:bg-pink-700 text-white font-bold py-3 px-6 rounded-xl shadow-md transition-colors transform hover:-translate-y-0.5 text-center">
				+ Nuevo Servicio
			</a>
		</div>
	</div>

	<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
		{% if servicios is empty %}
			<div class="p-12 text-center text-gray-500">
				<div class="flex justify-center mb-4">
					<div class="w-16 h-16 bg-pink-100 rounded-2xl flex items-center justify-center">
						<svg class="w-8 h-8 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"/>
						</svg>
					</div>
				</div>
				<p class="font-bold text-lg text-gray-900 mb-1">No tienes servicios todavía</p>
				<p>¡Crea el primero para que tus clientes puedan reservar!</p>
			</div>
		{% else %}
			{# --- Desktop: tabla --- #}
			<div class="hidden md:block overflow-x-auto">
				<table class="w-full text-left border-collapse">
					<thead>
						<tr class="text-gray-400 text-xs uppercase bg-gray-50 border-b border-gray-100">
							<th class="px-6 py-4 font-semibold">Servicio</th>
							<th class="px-6 py-4 font-semibold">Precio</th>
							<th class="px-6 py-4 font-semibold">Duración</th>
							<th class="px-6 py-4 font-semibold">Local</th>
							<th class="px-6 py-4 font-semibold text-center">Estado</th>
							<th class="px-6 py-4 font-semibold text-right">Acciones</th>
						</tr>
					</thead>
					<tbody class="text-sm text-gray-700 divide-y divide-gray-50">
						{% for servicio in servicios %}
							<tr class="hover:bg-gray-50 transition {% if not servicio.activo %}opacity-60{% endif %}">
								<td class="px-6 py-4">
									<span class="font-bold text-gray-900 block text-base">{{ servicio.nombre }}</span>
									<span class="text-xs font-bold text-pink-600 uppercase tracking-wider">{{ servicio.categoria }}</span>
								</td>
								<td class="px-6 py-4">
									<span class="font-extrabold text-gray-900 text-lg">{{ servicio.precio|number_format(2, ',', '.') }}€</span>
								</td>
								<td class="px-6 py-4 font-semibold text-gray-500">
									⏱ {{ servicio.duration }} min
								</td>
								<td class="px-6 py-4 font-medium text-gray-500">
									{% if servicio.local %}
										<span class="inline-block bg-gray-100 text-gray-700 text-xs px-2.5 py-1 rounded-md font-bold border border-gray-200">{{ servicio.local.nombre }}</span>
									{% else %}
										<span class="text-xs text-gray-400 font-semibold italic">Todos</span>
									{% endif %}
								</td>
								<td class="px-6 py-4 text-center">
									{% if servicio.activo %}
										<span class="px-3 py-1 text-sm font-bold rounded-full bg-green-100 text-green-700">Activo</span>
									{% else %}
										<span class="px-3 py-1 text-sm font-bold rounded-full bg-red-100 text-red-700">Oculto</span>
									{% endif %}
								</td>
								<td class="px-6 py-4 text-right">
									<div class="flex justify-end gap-2">
										<a href="{{ path('app_admin_servicio_editar', {'id': servicio.id}) }}" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold px-4 py-2 rounded-xl text-sm transition-colors">Editar</a>
										{% if servicio.activo %}
											<a href="{{ path('app_admin_servicio_eliminar', {'id': servicio.id}) }}" onclick="return confirm('¿Ocultar este servicio? Los clientes ya no podrán reservarlo.')" class="bg-red-50 hover:bg-red-500 hover:text-white text-red-600 font-bold px-4 py-2 rounded-xl border border-red-200 text-sm transition-colors">Desactivar</a>
										{% endif %}
									</div>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

			{# --- Mobile: tarjetas --- #}
			<div class="block md:hidden divide-y divide-gray-100">
				{% for servicio in servicios %}
					<div class="p-5 {% if not servicio.activo %}opacity-60 bg-gray-50/50{% endif %}">
						<div class="flex justify-between items-start mb-3">
							<div>
								<span class="font-bold text-gray-900 block text-lg leading-tight">{{ servicio.nombre }}</span>
								<span class="text-xs font-bold text-pink-600 uppercase tracking-wider block mt-0.5">{{ servicio.categoria }}</span>
							</div>
							<div class="text-right">
								<span class="block font-extrabold text-gray-900 text-xl">{{ servicio.precio|number_format(2, ',', '.') }}€</span>
								<span class="text-xs text-gray-400 font-semibold">⏱ {{ servicio.duration }} min</span>
							</div>
						</div>

						<div class="mb-4 bg-gray-50 p-3 rounded-lg flex flex-col gap-2">
							<div class="flex justify-between items-center border-b border-gray-200 pb-2">
								<span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Local</span>
								<span class="font-semibold text-gray-700 text-sm">
									{{ servicio.local.nombre|default('Todos') }}
								</span>
							</div>
							<div class="flex justify-between items-center pt-1">
								<span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Estado</span>
								{% if servicio.activo %}
									<span class="px-2.5 py-0.5 text-xs font-bold rounded-full bg-green-100 text-green-700">Activo</span>
								{% else %}
									<span class="px-2.5 py-0.5 text-xs font-bold rounded-full bg-red-100 text-red-700">Oculto</span>
								{% endif %}
							</div>
						</div>

						<div class="flex gap-2 mt-3">
							<a href="{{ path('app_admin_servicio_editar', {'id': servicio.id}) }}" class="flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2.5 rounded-xl text-sm transition-colors">
								Editar
							</a>
							{% if servicio.activo %}
								<a href="{{ path('app_admin_servicio_eliminar', {'id': servicio.id}) }}" onclick="return confirm('¿Desactivar este servicio?')" class="flex-1 text-center bg-red-50 hover:bg-red-500 hover:text-white text-red-600 font-bold py-2.5 rounded-xl border border-red-200 text-sm transition-colors">
									Desactivar
								</a>
							{% endif %}
						</div>
					</div>
				{% endfor %}
			</div>
		{% endif %}
	</div>
{% endblock %}

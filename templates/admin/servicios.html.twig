{% extends 'base.html.twig' %}

{% block title %}Gestionar Servicios | Admin Venus
{% endblock %}

{% block body %}
	<div class="mb-8 flex justify-between items-center">
		<div>
			<h1 class="text-3xl font-extrabold text-gray-900">Catálogo de Servicios</h1>
			<p class="text-gray-500 mt-1">Añade, edita o elimina lo que ofreces.</p>
		</div>
		<div class="flex gap-3">
			<a href="{{ path('app_admin_dashboard') }}" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-xl transition-colors">
				&larr; Volver al Panel
			</a>
			<a href="{{ path('app_admin_servicio_nuevo') }}" class="bg-gray-900 hover:bg-pink-600 text-white font-bold py-3 px-6 rounded-xl shadow-md transition-colors transform hover:-translate-y-0.5">
				+ Nuevo Servicio
			</a>
		</div>
	</div>

	<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
		<table class="w-full text-left border-collapse">
			<thead>
				<tr class="text-gray-400 text-xs uppercase bg-gray-50 border-b border-gray-100">
					<th class="px-6 py-4 font-semibold">Servicio</th>
					<th class="px-6 py-4 font-semibold">Precio / Tiempo</th>
					<th class="px-6 py-4 font-semibold text-center">Estado</th>
					<th class="px-6 py-4 font-semibold text-right">Acciones</th>
				</tr>
			</thead>
			<tbody class="text-sm text-gray-700">
				{% for servicio in servicios %}
					<tr class="border-b border-gray-50 hover:bg-gray-50 transition {% if not servicio.activo %}opacity-50{% endif %}">
						<td class="px-6 py-4">
							<span class="font-bold text-gray-900 block">{{ servicio.nombre }}</span>
							<span class="text-xs text-gray-400 uppercase tracking-wider font-bold">{{ servicio.categoria }}</span>
						</td>
						<td class="px-6 py-4">
							<span class="font-extrabold text-pink-600 text-lg">{{ servicio.precio }}€</span><br>
							<span class="text-gray-500 text-xs">⏱
								{{ servicio.duration }}
								min</span>
						</td>
						<td class="px-6 py-4 text-center">
							{% if servicio.activo %}
								<span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-xs font-bold">Activo</span>
							{% else %}
								<span class="px-3 py-1 bg-red-100 text-red-800 rounded-full text-xs font-bold">Oculto</span>
							{% endif %}
						</td>
						<td class="px-6 py-4 text-right">
							<a href="{{ path('app_admin_servicio_editar', {'id': servicio.id}) }}" class="text-blue-500 hover:text-blue-700 font-bold mr-3 transition-colors">Editar</a>
							{% if servicio.activo %}
								<a href="{{ path('app_admin_servicio_eliminar', {'id': servicio.id}) }}" onclick="return confirm('¿Ocultar este servicio? Los clientes ya no podrán reservarlo.')" class="text-red-500 hover:text-red-700 font-bold transition-colors">Desactivar</a>
							{% endif %}
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="4" class="px-6 py-8 text-center text-gray-500">No tienes servicios. ¡Crea el primero!</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
{% endblock %}

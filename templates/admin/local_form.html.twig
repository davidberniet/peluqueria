{% extends 'base.html.twig' %}

{% block title %}Datos del Local | Panel Admin | Venus{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">

	<div class="mb-8">
		<a href="{{ path('app_admin_locales') }}" class="text-sm text-gray-400 hover:text-pink-600 transition mb-2 inline-flex items-center gap-1">
			← Volver a locales
		</a>
		<h1 class="text-3xl font-extrabold text-gray-900">
			{% if editando %}🏪 Editar Local{% else %}🏪 Nuevo Local{% endif %}
		</h1>
		<p class="text-gray-500 mt-1">Configura la información de este establecimiento.</p>
	</div>

	{# FLASH MESSAGES #}
	{% for msg in app.flashes('success') %}
		<div class="mb-6 bg-green-50 border border-green-200 text-green-700 font-semibold px-5 py-4 rounded-xl">✅ {{ msg }}</div>
	{% endfor %}

	<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
		<div class="p-6">
			{{ form_start(form, {'attr': {'class': 'flex flex-col gap-6'}}) }}

			{# Errores globales #}
			{% if form.vars.errors|length > 0 %}
				<div class="bg-red-50 border border-red-200 text-red-700 font-semibold px-4 py-3 rounded-xl text-sm">
					{% for error in form.vars.errors %}❌ {{ error.message }}{% endfor %}
				</div>
			{% endif %}

			<div>
				<label class="block text-sm font-bold text-gray-600 mb-2">Nombre del local</label>
				{{ form_widget(form.nombre) }}
				{{ form_errors(form.nombre) }}
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
				<div>
					<label class="block text-sm font-bold text-gray-600 mb-2">Dirección</label>
					{{ form_widget(form.direccion) }}
					{{ form_errors(form.direccion) }}
				</div>
				<div>
					<label class="block text-sm font-bold text-gray-600 mb-2">Ciudad</label>
					{{ form_widget(form.ciudad) }}
					{{ form_errors(form.ciudad) }}
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
				<div>
					<label class="block text-sm font-bold text-gray-600 mb-2">Teléfono <span class="font-normal text-gray-400">(opcional)</span></label>
					{{ form_widget(form.telefono) }}
					{{ form_errors(form.telefono) }}
				</div>
				<div>
					<label class="block text-sm font-bold text-gray-600 mb-2">Email de contacto <span class="font-normal text-gray-400">(opcional)</span></label>
					{{ form_widget(form.email) }}
					{{ form_errors(form.email) }}
				</div>
			</div>

			<div class="flex items-center gap-3 bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3">
				{{ form_widget(form.activo) }}
				<label class="text-base font-semibold text-gray-700 cursor-pointer">{{ form_label(form.activo) }}</label>
				{{ form_errors(form.activo) }}
			</div>

			<div class="flex flex-col md:flex-row justify-end gap-3 pt-2 border-t border-gray-100">
				<button type="submit"
				        class="bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-8 rounded-xl shadow-sm transition-colors">
					💾 Guardar cambios
				</button>
			</div>

			{{ form_end(form) }}
		</div>
	</div>

	{# PREVIEW de la info actual #}
	{% if local.id %}
	<div class="mt-6 bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
		<h2 class="text-base font-extrabold text-gray-700 uppercase tracking-wide mb-4">📋 Vista previa actual</h2>
		<dl class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
			<div class="flex flex-col">
				<dt class="text-gray-400 font-semibold">Nombre</dt>
				<dd class="font-bold text-gray-900">{{ local.nombre }}</dd>
			</div>
			<div class="flex flex-col">
				<dt class="text-gray-400 font-semibold">Ciudad</dt>
				<dd class="font-bold text-gray-900">{{ local.ciudad }}</dd>
			</div>
			<div class="flex flex-col">
				<dt class="text-gray-400 font-semibold">Dirección</dt>
				<dd class="font-bold text-gray-900">{{ local.direccion }}</dd>
			</div>
			<div class="flex flex-col">
				<dt class="text-gray-400 font-semibold">Teléfono</dt>
				<dd class="font-bold text-gray-900">{{ local.telefono ?? '—' }}</dd>
			</div>
			<div class="flex flex-col">
				<dt class="text-gray-400 font-semibold">Email</dt>
				<dd class="font-bold text-gray-900">{{ local.email ?? '—' }}</dd>
			</div>
			<div class="flex flex-col">
				<dt class="text-gray-400 font-semibold">Estado</dt>
				<dd>
					{% if local.activo %}
						<span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-bold">✅ Activo</span>
					{% else %}
						<span class="px-3 py-1 bg-red-100 text-red-700 rounded-full text-xs font-bold">⛔ Inactivo</span>
					{% endif %}
				</dd>
			</div>
		</dl>
	</div>
	{% endif %}

</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ editando ? 'Editar' : 'Nuevo' }} Servicio | Admin Venus{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto my-10">
    <div class="mb-8">
        <a href="{{ path('app_admin_servicios') }}" class="text-pink-600 font-bold hover:underline mb-4 inline-block">&larr; Volver al catálogo</a>
        <h1 class="text-3xl font-extrabold text-gray-900">{{ editando ? 'Editar Servicio' : 'Crear Nuevo Servicio' }}</h1>
    </div>

    <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">
        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    {{ form_label(form.nombre, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.nombre) }}
                    {{ form_errors(form.nombre, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                </div>
                
                <div>
                    {{ form_label(form.categoria, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.categoria) }}
                    {{ form_errors(form.categoria, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                </div>

                <div>
                    {{ form_label(form.local, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.local) }}
                    {{ form_errors(form.local, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                </div>

                <div>
                    {{ form_label(form.precio, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.precio) }}
                    {{ form_errors(form.precio, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                </div>

                <div>
                    {{ form_label(form.duration, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.duration) }}
                    {{ form_errors(form.duration, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                </div>
            </div>

            <div class="flex items-center mt-4 bg-pink-50 p-4 rounded-xl border border-pink-100">
                {{ form_widget(form.activo) }}
                {{ form_label(form.activo, null, {'label_attr': {'class': 'ml-3 text-sm font-bold text-gray-900 cursor-pointer'}}) }}
            </div>

            <button type="submit" class="w-full bg-gray-900 hover:bg-pink-600 text-white font-bold py-4 px-4 rounded-xl shadow-md transition-all mt-6 transform hover:-translate-y-0.5 text-lg">
                {{ editando ? 'Guardar Cambios' : 'Añadir Servicio' }}
            </button>
            
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
{% extends 'admin/base.html.twig' %}

{% block title %}Configuración | Venus{% endblock %}

{% block admin_content %}

	<style>
		input[type="time"] {
			-webkit-appearance: none;
			appearance: none;
			min-height: 52px;
		}
		input[type="time"]::-webkit-date-and-time-value {
			text-align: left;
		}
	</style>

	{# ===== CABECERA ===== #}
	<div class="mb-6">
		<h1 class="text-3xl font-extrabold text-gray-900">Configuración del Negocio</h1>
		<p class="text-gray-500 mt-1">Gestiona cuándo y cómo se pueden hacer reservas.</p>
	</div>

	{# ===== FLASH MESSAGES ===== #}
	{% for msg in app.flashes('success') %}
		<div class="mb-6 bg-green-50 border border-green-200 text-green-700 font-semibold px-5 py-4 rounded-xl">{{ msg }}</div>
	{% endfor %}
	{% for msg in app.flashes('error') %}
		<div class="mb-6 bg-red-50 border border-red-200 text-red-700 font-semibold px-5 py-4 rounded-xl">{{ msg }}</div>
	{% endfor %}

	{# ===== SELECTOR DE LOCAL (solo si hay más de uno) ===== #}
	{% if locales|length > 1 %}
	<div class="mb-6 bg-white rounded-2xl shadow-sm border border-gray-100 p-4 flex flex-wrap items-center gap-3">
		<span class="text-sm font-bold text-gray-500 uppercase tracking-wider shrink-0">Local:</span>
		{% for local in locales %}
			<a href="{{ path('app_admin_configuracion', {local: local.id}) }}"
			   class="px-4 py-2 rounded-xl text-sm font-bold transition-colors
			          {{ local.id == localActivo.id ? 'bg-pink-600 text-white shadow-sm' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' }}">
				{{ local.nombre }}
			</a>
		{% endfor %}
	</div>
	{% else %}
	<div class="mb-6 flex items-center gap-3">
		<div class="bg-pink-100 text-pink-700 font-bold text-sm px-4 py-2 rounded-xl">
			{{ localActivo.nombre }}
		</div>
		<span class="text-gray-400 text-sm">— {{ localActivo.direccion }}, {{ localActivo.ciudad }}</span>
	</div>
	{% endif %}

	{# ===== 1. HORARIO BASE ===== #}
	<div id="horario" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
		<div class="flex items-center gap-4 p-6 border-b border-gray-100 bg-gray-50">
			<div>
				<h2 class="text-lg font-semibold text-gray-900">Horario de trabajo</h2>
				<p class="text-gray-400 text-xs">Las franjas en las que se aceptan reservas.</p>
			</div>
		</div>
		<div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">Añadir franja horaria</h3>
				<form method="POST" action="{{ path('admin_horario_nuevo') }}" class="flex flex-col gap-4">
					<input type="hidden" name="local_id" value="{{ localActivo.id }}">
					<div class="grid grid-cols-2 gap-4">
						<div>
							<label class="block text-sm font-bold text-gray-600 mb-2">Apertura</label>
							<input type="time" name="hora_apertura" required class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
						</div>
						<div>
							<label class="block text-sm font-bold text-gray-600 mb-2">Cierre</label>
							<input type="time" name="hora_cierre" required class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
						</div>
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Intervalo entre citas</label>
						<select name="intervalo" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							<option value="15">Cada 15 minutos</option>
							<option value="30" selected>Cada 30 minutos</option>
							<option value="60">Cada hora</option>
						</select>
					</div>
					<button type="submit" class="bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-6 rounded-xl shadow-sm transition-colors text-base">
						Guardar franja
					</button>
				</form>
			</div>

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">Franjas activas</h3>
				{% if horarios is empty %}
					<div class="flex items-start gap-3 bg-red-50 border-2 border-red-200 rounded-xl p-5">
						<span class="text-2xl">⚠️</span>
						<p class="text-red-600 text-base font-bold">Sin franjas configuradas — los clientes no verán horas disponibles.</p>
					</div>
				{% else %}
					<ul class="flex flex-col gap-3">
						{% for horario in horarios %}
							<li class="flex items-center justify-between bg-green-50 border border-green-100 rounded-xl px-5 py-4">
								<div class="flex items-center gap-3">
									<div>
										<span class="font-extrabold text-gray-800 text-base">
											{{ horario.horaApertura|date('H:i') }}
											–
											{{ horario.horaCierre|date('H:i') }}
										</span>
										<span class="ml-2 text-sm text-gray-500">cada
											{{ horario.intervaloMinutos }}
											min</span>
									</div>
								</div>
								<a href="{{ path('admin_horario_eliminar', {'id': horario.id}) }}" onclick="return confirm('¿Eliminar esta franja horaria?')" class="bg-red-100 hover:bg-red-500 hover:text-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm transition-colors">
									Eliminar
								</a>
							</li>
						{% endfor %}
					</ul>
				{% endif %}
			</div>
		</div>
	</div>

	{# ===== 2. REGLAS RECURRENTES ===== #}
	<div id="reglas" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
		<div class="flex items-center gap-4 p-6 border-b border-gray-100 bg-gray-50">
			<div>
				<h2 class="text-lg font-semibold text-gray-900">Reglas de horario</h2>
				<p class="text-gray-400 text-xs">Días o franjas que siempre están cerrados.</p>
			</div>
		</div>
		<div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">Añadir regla recurrente</h3>
				<form method="POST" action="{{ path('admin_regla_horario_nueva') }}" class="flex flex-col gap-4">
					<input type="hidden" name="local_id" value="{{ localActivo.id }}">
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Día de la semana</label>
						<select name="dia_semana" required class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							<option value="1">Lunes</option>
							<option value="2">Martes</option>
							<option value="3">Miércoles</option>
							<option value="4">Jueves</option>
							<option value="5">Viernes</option>
							<option value="6">Sábado</option>
							<option value="0">Domingo</option>
						</select>
					</div>

					<label class="flex items-center gap-3 bg-gray-50 border-2 border-gray-200 rounded-xl px-4 py-3 cursor-pointer hover:border-pink-300 transition-colors">
						<input type="checkbox" id="toggle-franja" class="w-5 h-5 rounded accent-pink-600">
						<span class="text-base text-gray-700 font-semibold">Solo bloquear una franja horaria (no el día entero)</span>
					</label>

					<div id="bloque-franja" class="hidden flex flex-col gap-3">
						<div class="grid grid-cols-2 gap-4">
							<div>
								<label class="block text-sm font-bold text-gray-600 mb-2">Desde</label>
								<input type="time" name="hora_desde" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							</div>
							<div>
								<label class="block text-sm font-bold text-gray-600 mb-2">Hasta</label>
								<input type="time" name="hora_hasta" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							</div>
						</div>
					</div>

					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">
							Motivo
							<span class="font-normal text-gray-400">(opcional)</span>
						</label>
						<input type="text" name="motivo" placeholder="Ej: Domingo cerrado" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
					</div>

					<button type="submit" class="bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-6 rounded-xl shadow-sm transition-colors text-base">
						Guardar regla
					</button>
				</form>
			</div>

			<div>
				{% set dias = {0: 'Domingo', 1: 'Lunes', 2: 'Martes', 3: 'Miércoles', 4: 'Jueves', 5: 'Viernes', 6: 'Sábado'} %}
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">Reglas activas</h3>
				{% if reglasHorario is empty %}
					<p class="text-gray-400 text-base py-4">No hay reglas configuradas.</p>
				{% else %}
					<ul class="flex flex-col gap-3">
						{% for regla in reglasHorario %}
							<li class="flex items-center justify-between bg-gray-50 border border-gray-200 rounded-xl px-5 py-4">
								<div class="flex items-start gap-3">
									<div>
										<span class="font-extrabold text-gray-800 text-base">{{ dias[regla.diaSemana] }}</span>
										{% if regla.horaDesde and regla.horaHasta %}
											<span class="ml-2 text-sm text-pink-600 font-bold">
												{{ regla.horaDesde|date('H:i') }}
												–
												{{ regla.horaHasta|date('H:i') }}
											</span>
										{% else %}
											<span class="ml-2 text-sm bg-red-100 text-red-600 font-bold px-2 py-0.5 rounded-full">
												Día completo
											</span>
										{% endif %}
										{% if regla.motivo %}
											<p class="text-sm text-gray-400 mt-0.5">{{ regla.motivo }}</p>
										{% endif %}
									</div>
								</div>
								<a href="{{ path('admin_regla_horario_eliminar', {'id': regla.id}) }}" onclick="return confirm('¿Eliminar esta regla?')" class="bg-red-100 hover:bg-red-500 hover:text-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm transition-colors shrink-0 ml-3">
									Eliminar
								</a>
							</li>
						{% endfor %}
					</ul>
				{% endif %}
			</div>
		</div>
	</div>

	{# ===== 3. DÍAS BLOQUEADOS PUNTUALES / VACACIONES ===== #}
	<div id="bloqueados" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-10">
		<div class="flex items-center gap-4 p-6 border-b border-gray-100 bg-gray-50">
			<div>
				<h2 class="text-lg font-semibold text-gray-900">Días bloqueados</h2>
				<p class="text-gray-400 text-xs">Fechas concretas cerradas: festivos, vacaciones, etc.</p>
			</div>
		</div>
		<div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">Bloquear fecha o periodo</h3>
				<form method="POST" action="{{ path('admin_dias_bloqueados') }}" class="flex flex-col gap-4">
					<input type="hidden" name="local_id" value="{{ localActivo.id }}">

					{# Toggle día único / rango #}
					<div class="flex rounded-xl overflow-hidden border-2 border-gray-200 text-sm font-bold">
						<label class="flex-1 flex items-center justify-center gap-2 py-3 px-4 cursor-pointer transition-colors has-[:checked]:bg-gray-900 has-[:checked]:text-white bg-white text-gray-600">
							<input type="radio" name="tipo_bloqueo" value="dia" class="sr-only" checked onchange="toggleTipoBloqueo(this.value)">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
							</svg>
							Un día
						</label>
						<label class="flex-1 flex items-center justify-center gap-2 py-3 px-4 cursor-pointer transition-colors has-[:checked]:bg-gray-900 has-[:checked]:text-white bg-white text-gray-600 border-l-2 border-gray-200">
							<input type="radio" name="tipo_bloqueo" value="rango" class="sr-only" onchange="toggleTipoBloqueo(this.value)">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
							</svg>
							Periodo
						</label>
					</div>

					{# Fecha única #}
					<div id="bloqueo-dia">
						<label class="block text-sm font-bold text-gray-600 mb-2">Fecha</label>
						<input type="date" name="fecha" id="campo-fecha-dia" required min="{{ "now"|date('Y-m-d') }}"
							   class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
					</div>

					{# Rango de fechas #}
					<div id="bloqueo-rango" class="hidden flex flex-col gap-3">
						<div class="grid grid-cols-2 gap-4">
							<div>
								<label class="block text-sm font-bold text-gray-600 mb-2">Desde</label>
								<input type="date" name="fecha" id="campo-fecha-desde" min="{{ "now"|date('Y-m-d') }}"
									   class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							</div>
							<div>
								<label class="block text-sm font-bold text-gray-600 mb-2">Hasta</label>
								<input type="date" name="fecha_fin" id="campo-fecha-hasta" min="{{ "now"|date('Y-m-d') }}"
									   class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							</div>
						</div>
					</div>

					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">
							Motivo
							<span class="font-normal text-gray-400">(opcional)</span>
						</label>
						<input type="text" name="motivo" placeholder="Ej: Vacaciones de agosto"
							   class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
					</div>
					<button type="submit" class="bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-6 rounded-xl shadow-sm transition-colors text-base">
						Bloquear
					</button>
				</form>
			</div>

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">Bloqueos activos</h3>
				{% if diasBloqueados is empty %}
					<p class="text-gray-400 text-base py-4">No hay días bloqueados.</p>
				{% else %}
					<ul class="flex flex-col gap-3">
						{% for dia in diasBloqueados %}
							<li class="flex items-center justify-between bg-red-50 border border-red-100 rounded-xl px-5 py-4">
								<div class="flex items-center gap-3">
									<div class="bg-red-100 p-2 rounded-lg shrink-0">
										<svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
										</svg>
									</div>
									<div>
										{% if dia.esRango %}
											<span class="font-extrabold text-gray-800 text-base">
												{{ dia.fecha|date('d/m/Y') }} — {{ dia.fechaFin|date('d/m/Y') }}
											</span>
											<span class="ml-2 text-xs bg-orange-100 text-orange-700 font-bold px-2 py-0.5 rounded-full">Periodo</span>
										{% else %}
											<span class="font-extrabold text-gray-800 text-base">{{ dia.fecha|date('d/m/Y') }}</span>
										{% endif %}
										{% if dia.motivo %}
											<p class="text-sm text-gray-500 mt-0.5">{{ dia.motivo }}</p>
										{% endif %}
									</div>
								</div>
								<a href="{{ path('admin_dias_bloqueados_eliminar', {'id': dia.id}) }}"
								   onclick="return confirm('¿Eliminar este bloqueo?')"
								   class="bg-red-100 hover:bg-red-500 hover:text-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm transition-colors shrink-0 ml-3">
									Eliminar
								</a>
							</li>
						{% endfor %}
					</ul>
				{% endif %}
			</div>
		</div>
	</div>

	<script>
		document.getElementById('toggle-franja').addEventListener('change', function () {
			document.getElementById('bloque-franja').classList.toggle('hidden', !this.checked);
		});

		function toggleTipoBloqueo(valor) {
			const diaDiv   = document.getElementById('bloqueo-dia');
			const rangoDiv = document.getElementById('bloqueo-rango');
			const campoFechaDia   = document.getElementById('campo-fecha-dia');
			const campoFechaDesde = document.getElementById('campo-fecha-desde');
			const campoFechaHasta = document.getElementById('campo-fecha-hasta');

			if (valor === 'rango') {
				diaDiv.classList.add('hidden');
				rangoDiv.classList.remove('hidden');
				campoFechaDia.required   = false;
				campoFechaDesde.required = true;
				campoFechaHasta.required = true;
			} else {
				diaDiv.classList.remove('hidden');
				rangoDiv.classList.add('hidden');
				campoFechaDia.required   = true;
				campoFechaDesde.required = false;
				campoFechaHasta.required = false;
			}
		}

		// Asegurar que fecha_hasta >= fecha_desde
		document.getElementById('campo-fecha-desde')?.addEventListener('change', function () {
			const hasta = document.getElementById('campo-fecha-hasta');
			if (hasta.value && hasta.value < this.value) {
				hasta.value = this.value;
			}
			hasta.min = this.value;
		});
	</script>

{% endblock %}

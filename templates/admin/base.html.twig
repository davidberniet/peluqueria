{% extends 'base.html.twig' %}

{% block navbar %}{% endblock %}
{% block site_footer %}{% endblock %}

{% block main_wrapper %}
{% set currentRoute = app.request.attributes.get('_route') %}

{# ===== LAYOUT ADMIN: sidebar + contenido ===== #}
<div class="flex min-h-screen">

	{# ===== OVERLAY MOBILE ===== #}
	<div id="admin-sidebar-overlay"
		 class="fixed inset-0 bg-black/50 z-30 hidden lg:hidden"
		 onclick="toggleAdminSidebar()">
	</div>

	{# ===== SIDEBAR ===== #}
	<aside id="admin-sidebar"
		   class="fixed top-0 left-0 h-full w-64 bg-gray-900 z-40 flex flex-col
		          transform -translate-x-full transition-transform duration-300 ease-in-out
		          lg:sticky lg:top-0 lg:h-screen lg:translate-x-0 lg:flex lg:shrink-0">

		{# Cabecera sidebar #}
		<div class="px-5 py-5 border-b border-gray-700">
			<div class="flex items-center gap-3">
				<img src="{{ asset('images/logoVenus.png') }}" alt="Venus" class="h-9 w-auto mix-blend-screen opacity-90">
				<div>
					<p class="text-xs font-bold text-pink-400 uppercase tracking-widest">Admin</p>
					{% if app.user %}
					<p class="text-sm font-semibold text-white leading-tight truncate">{{ app.user.nombre }}</p>
					{% endif %}
				</div>
			</div>
		</div>

		{# Navegación principal #}
		<nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">

			<p class="px-3 pb-2 text-xs font-bold text-gray-500 uppercase tracking-widest">Gestión</p>

			{# Dashboard #}
			<a href="{{ path('app_admin_dashboard') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
			          {{ currentRoute == 'app_admin_dashboard' ? 'bg-pink-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
				</svg>
				Dashboard
			</a>

			{# Citas #}
			<a href="{{ path('app_admin_citas') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
			          {{ currentRoute == 'app_admin_citas' ? 'bg-pink-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
				</svg>
				Citas
			</a>

			{# Servicios #}
			<a href="{{ path('app_admin_servicios') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
			          {{ currentRoute in ['app_admin_servicios', 'app_admin_servicio_nuevo', 'app_admin_servicio_editar'] ? 'bg-pink-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M5 3l14 9-14 9V3z"/>
				</svg>
				Servicios
			</a>

			{# Productos #}
			<a href="{{ path('app_admin_productos') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
			          {{ currentRoute in ['app_admin_productos', 'app_admin_producto_nuevo', 'app_admin_producto_editar'] ? 'bg-pink-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
				</svg>
				Productos
			</a>

			{# Empleados #}
			<a href="{{ path('app_admin_empleados') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
			          {{ currentRoute in ['app_admin_empleados', 'app_admin_empleado_nuevo', 'app_admin_empleado_editar'] ? 'bg-pink-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
				</svg>
				Empleados
			</a>

			{# Locales #}
			<a href="{{ path('app_admin_locales') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
			          {{ currentRoute in ['app_admin_locales', 'app_admin_local_nuevo', 'app_admin_local_editar'] ? 'bg-pink-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
				</svg>
				Locales
			</a>

			{# Mensajes de contacto #}
			<a href="{{ path('app_admin_mensajes') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
			          {{ currentRoute == 'app_admin_mensajes' ? 'bg-pink-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
				</svg>
				<span class="flex-1">Mensajes</span>
				{% if mensajesNoLeidos is defined and mensajesNoLeidos > 0 %}
					<span class="bg-pink-500 text-white text-xs font-extrabold px-2 py-0.5 rounded-full">{{ mensajesNoLeidos }}</span>
				{% endif %}
			</a>

			{# Separador #}
			<div class="my-3 border-t border-gray-700"></div>
			<p class="px-3 pb-2 text-xs font-bold text-gray-500 uppercase tracking-widest">Sistema</p>

			{# Configuración #}
			<a href="{{ path('app_admin_configuracion') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
			          {{ currentRoute == 'app_admin_configuracion' ? 'bg-pink-600 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }}">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
				</svg>
				Configuración
			</a>

			{# Separador #}
			<div class="my-3 border-t border-gray-700"></div>

			{# Ver tienda #}
			<a href="{{ path('app_home') }}"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors text-gray-300 hover:bg-gray-800 hover:text-white">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
				</svg>
				Ir a la web
			</a>

			{# Cerrar sesión #}
			<a href="{{ path('app_logout') }}"
			   onclick="return confirm('¿Estás seguro de que quieres cerrar sesión?')"
			   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors text-red-400 hover:bg-red-900/30 hover:text-red-300">
				<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
				</svg>
				Cerrar sesión
			</a>

		</nav>

		{# Pie del sidebar #}
		<div class="px-5 py-4 border-t border-gray-700">
			<p class="text-xs text-gray-600 text-center">Venus Admin &copy; {{ 'now'|date('Y') }}</p>
		</div>

	</aside>

	{# ===== ÁREA DE CONTENIDO ===== #}
	<div class="flex-1 flex flex-col min-w-0 bg-gray-100">

		{# Top bar solo en mobile #}
		<div class="lg:hidden flex items-center gap-3 bg-gray-900 px-4 py-3 sticky top-0 z-20 shadow">
			<button onclick="toggleAdminSidebar()"
					class="text-gray-300 hover:text-white focus:outline-none p-1.5 rounded-lg hover:bg-gray-800 transition-colors">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
				</svg>
			</button>
			<span class="text-sm font-bold text-white">Panel Admin</span>
			<img src="{{ asset('images/logoVenus.png') }}" alt="Venus" class="h-7 w-auto mix-blend-screen opacity-80 ml-auto">
		</div>

		{# Contenido de la página #}
		<main class="flex-1 px-4 sm:px-6 lg:px-8 py-8">
			{% block admin_content %}{% endblock %}
		</main>

	</div>

</div>

<script>
	function toggleAdminSidebar() {
		const sidebar = document.getElementById('admin-sidebar');
		const overlay = document.getElementById('admin-sidebar-overlay');
		const isOpen = !sidebar.classList.contains('-translate-x-full');
		if (isOpen) {
			sidebar.classList.add('-translate-x-full');
			overlay.classList.add('hidden');
		} else {
			sidebar.classList.remove('-translate-x-full');
			overlay.classList.remove('hidden');
		}
	}
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}
	{{ editando ? 'Editar Empleado' : 'Nuevo Empleado' }}
	| Venus
{% endblock %}

{% block body %}
	<div class="max-w-2xl mx-auto">

		<div class="mb-8">
			<a href="{{ path('app_admin_empleados') }}" class="text-sm text-gray-400 hover:text-pink-600 transition mb-2 inline-flex items-center gap-1">
				← Volver a empleados
			</a>
			<h1 class="text-3xl font-extrabold text-gray-900">
				{{ editando ? ' Editar empleado' : 'Nuevo empleado' }}
			</h1>
			<p class="text-gray-500 mt-1">
				{% if editando %}
					Modifica los datos de
					<strong>{{ empleado.nombre }}</strong>.
				{% else %}
					Rellena los datos del nuevo miembro del equipo.<br>
					<span class="text-xs text-gray-400">La contraseña inicial será
						<strong>Venus2026!</strong>
						— el empleado puede cambiarla desde su perfil.</span>
				{% endif %}
			</p>
		</div>

		<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
			<div class="p-6">
				{{ form_start(form, {'attr': {'class': 'flex flex-col gap-6'}}) }}

				{# Errores globales #}
				{% if form.vars.errors|length > 0 %}
					<div class="bg-red-50 border border-red-200 text-red-700 font-semibold px-4 py-3 rounded-xl text-sm">
						{% for error in form.vars.errors %}
							{{ error.message }}
						{% endfor %}
					</div>
				{% endif %}

				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Nombre completo</label>
						{{ form_widget(form.nombre) }}
						{{ form_errors(form.nombre) }}
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Email</label>
						{{ form_widget(form.email) }}
						{{ form_errors(form.email) }}
					</div>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Teléfono
							<span class="font-normal text-gray-400">(opcional)</span>
						</label>
						{{ form_widget(form.telefono) }}
						{{ form_errors(form.telefono) }}
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Rol</label>
						{{ form_widget(form.roles) }}
						{{ form_errors(form.roles) }}
						<p class="text-xs text-gray-400 mt-1">Mantén Ctrl (o Cmd en Mac) para seleccionar varios roles.</p>
					</div>
				</div>

				<div class="flex flex-col md:flex-row justify-between gap-3 pt-2 border-t border-gray-100">
					<a href="{{ path('app_admin_empleados') }}" class="text-center bg-white border-2 border-gray-200 hover:border-gray-400 text-gray-700 font-bold py-3 px-6 rounded-xl transition-colors">
						Cancelar
					</a>
					<button type="submit" class="bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-8 rounded-xl shadow-sm transition-colors">
						{{ editando ? 'Guardar cambios' : 'Crear empleado' }}
					</button>
				</div>

				{{ form_end(form) }}
			</div>
		</div>

	</div>
{% endblock %}

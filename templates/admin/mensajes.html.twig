{% extends 'admin/base.html.twig' %}

{% block title %}Mensajes de contacto | Admin Venus{% endblock %}

{% block admin_content %}
<div class="mb-8 flex items-center justify-between gap-4 flex-wrap">
    <div>
        <h1 class="text-2xl font-extrabold text-gray-900">Mensajes de contacto</h1>
        <p class="text-gray-500 text-sm mt-1">Mensajes recibidos a través del formulario de la web</p>
    </div>
    {% set noLeidos = mensajes|filter(m => not m.leido)|length %}
    {% if noLeidos > 0 %}
        <span class="inline-flex items-center gap-1.5 bg-pink-100 text-pink-700 font-bold text-sm px-4 py-2 rounded-full">
            <span class="w-2 h-2 bg-pink-500 rounded-full"></span>
            {{ noLeidos }} sin leer
        </span>
    {% endif %}
</div>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="mb-4 px-4 py-3 rounded-xl text-sm font-semibold
            {{ label == 'success' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200' }}">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{% if mensajes is empty %}
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-16 text-center">
        <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
        </div>
        <p class="text-gray-500 font-semibold">No hay mensajes todavía</p>
        <p class="text-gray-400 text-sm mt-1">Los mensajes del formulario de contacto aparecerán aquí</p>
    </div>
{% else %}
    <div class="space-y-4">
        {% for mensaje in mensajes %}
        <div class="bg-white rounded-2xl shadow-sm border {{ not mensaje.leido ? 'border-pink-200 ring-1 ring-pink-100' : 'border-gray-100' }} overflow-hidden">
            <div class="flex items-start gap-4 p-5 sm:p-6">

                {# Indicador leído/no leído #}
                <div class="shrink-0 pt-0.5">
                    {% if not mensaje.leido %}
                        <span class="block w-2.5 h-2.5 bg-pink-500 rounded-full mt-1.5" title="No leído"></span>
                    {% else %}
                        <span class="block w-2.5 h-2.5 bg-gray-200 rounded-full mt-1.5" title="Leído"></span>
                    {% endif %}
                </div>

                {# Contenido #}
                <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-1">
                        <span class="font-extrabold text-gray-900 text-base">{{ mensaje.nombre }}</span>
                        <a href="mailto:{{ mensaje.email }}"
                           class="text-pink-600 hover:underline text-sm font-semibold truncate">{{ mensaje.email }}</a>
                        {% if not mensaje.leido %}
                            <span class="bg-pink-100 text-pink-700 text-xs font-bold px-2 py-0.5 rounded-full">Nuevo</span>
                        {% endif %}
                    </div>
                    <p class="text-sm font-bold text-gray-700 mb-2">{{ mensaje.asunto }}</p>
                    <p class="text-gray-500 text-sm leading-relaxed whitespace-pre-line">{{ mensaje.mensaje }}</p>
                </div>

                {# Meta y acciones #}
                <div class="shrink-0 flex flex-col items-end gap-3">
                    <span class="text-xs text-gray-400 font-medium whitespace-nowrap">
                        {{ mensaje.creadoEn|date('d/m/Y H:i') }}
                    </span>
                    <div class="flex items-center gap-2">
                        {% if not mensaje.leido %}
                        <a href="{{ path('app_admin_mensaje_leer', {id: mensaje.id}) }}"
                           title="Marcar como leído"
                           class="inline-flex items-center gap-1.5 text-xs font-bold text-gray-600 bg-gray-100 hover:bg-green-100 hover:text-green-700 px-3 py-1.5 rounded-lg transition-colors">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            Leído
                        </a>
                        {% endif %}
                        <a href="{{ path('app_admin_mensaje_eliminar', {id: mensaje.id}) }}"
                           title="Eliminar mensaje"
                           onclick="return confirm('¿Eliminar este mensaje?')"
                           class="inline-flex items-center gap-1.5 text-xs font-bold text-gray-600 bg-gray-100 hover:bg-red-100 hover:text-red-700 px-3 py-1.5 rounded-lg transition-colors">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            Eliminar
                        </a>
                    </div>
                </div>

            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Panel de Control | Venus
{% endblock %}

{% block body %}

	{# ===== CABECERA ===== #}
	<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
		<div>
			<h1 class="text-3xl font-extrabold text-gray-900">Panel de Control</h1>
			<p class="text-gray-500 mt-1">Bienvenido, Jefe. Aquí tienes el resumen de las citas.</p>
		</div>
		<div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
			<a href="{{ path('app_admin_productos') }}" class="bg-white border-2 border-gray-900 text-gray-900 hover:bg-gray-50 font-bold py-3 px-5 rounded-xl transition-colors flex items-center justify-center gap-2 text-base">
				🛍️ Tienda
			</a>
			<a href="{{ path('app_admin_servicios') }}" class="bg-gray-900 hover:bg-pink-600 text-white font-bold py-3 px-5 rounded-xl shadow-md transition-colors flex items-center justify-center gap-2 text-base">
				✂️ Servicios
			</a>
		</div>
	</div>

	{# ===== TARJETAS DE ESTADÍSTICAS ===== #}
	<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
		<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
			<div class="bg-pink-100 p-4 rounded-xl shrink-0">
				<span class="text-3xl">📅</span>
			</div>
			<div>
				<p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Citas Hoy</p>
				<p class="text-4xl font-extrabold text-gray-900">{{ citas_hoy }}</p>
			</div>
		</div>
		<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
			<div class="bg-green-100 p-4 rounded-xl shrink-0">
				<span class="text-3xl">💰</span>
			</div>
			<div>
				<p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Ingresos Hoy</p>
				<p class="text-4xl font-extrabold text-gray-900">{{ ingresos_hoy }}€</p>
			</div>
		</div>
		<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
			<div class="bg-blue-100 p-4 rounded-xl shrink-0">
				<span class="text-3xl">👥</span>
			</div>
			<div>
				<p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Clientes</p>
				<p class="text-4xl font-extrabold text-gray-900">{{ total_clientes }}</p>
			</div>
		</div>
	</div>

	{# ===== PRÓXIMAS CITAS ===== #}
	<div id="citas" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
		<div class="flex justify-between items-center p-6 border-b border-gray-100 bg-gray-50">
			<div>
				<h2 class="text-xl font-extrabold text-gray-900">📅 Próximas Citas</h2>
				<p class="text-gray-400 text-sm mt-0.5">Las 5 más cercanas</p>
			</div>
			<a href="{{ path('app_admin_citas') }}" class="bg-pink-600 hover:bg-pink-700 text-white font-bold py-2.5 px-5 rounded-xl transition-colors text-sm">
				Ver todas →
			</a>
		</div>

		{# --- Versión móvil: tarjetas --- #}
		<div class="block md:hidden divide-y divide-gray-100">
			{% for cita in citas|slice(0, 5) %}
				<div class="p-5">
					<div class="flex justify-between items-start mb-3">
						<div>
							<a href="{{ path('app_admin_cliente_ficha', {'id': cita.usuario.id}) }}" class="font-extrabold text-gray-900 text-lg hover:text-pink-600 transition">
								{{ cita.usuario.nombre }}
							</a>
							<p class="text-sm text-gray-500">{{ cita.usuario.email }}</p>
							{% if cita.usuario.telefono %}
								<p class="text-sm font-bold text-pink-600 mt-1">📞
									{{ cita.usuario.telefono }}</p>
							{% endif %}
						</div>
						<div class="text-right">
							<p class="font-extrabold text-pink-600 text-lg">{{ cita.fechaInicio|date('H:i') }}</p>
							<p class="text-sm text-gray-500">{{ cita.fechaInicio|date('d/m/Y') }}</p>
						</div>
					</div>
					<div class="flex justify-between items-center">
						<div>
							<p class="text-sm text-gray-700 font-semibold mb-2">
								{% for servicio in cita.servicios %}
									{{ servicio.nombre }}
									{% if not loop.last %}
										+
									{% endif %}
								{% else %}
									Cita General
								{% endfor %}
							</p>
							{% if cita.estado == 'Pendiente' %}
								<span class="px-3 py-1.5 bg-yellow-100 text-yellow-800 rounded-full text-sm font-bold">⏳ Pendiente</span>
							{% elseif cita.estado == 'Confirmada' %}
								<span class="px-3 py-1.5 bg-green-100 text-green-800 rounded-full text-sm font-bold">✅ Confirmada</span>
							{% else %}
								<span class="px-3 py-1.5 bg-red-100 text-red-800 rounded-full text-sm font-bold">❌ Cancelada</span>
							{% endif %}
						</div>
						<div class="flex flex-col gap-2">
							{% if cita.estado == 'Pendiente' %}
								<a href="{{ path('app_admin_cita_confirmar', {'id': cita.id}) }}" class="bg-green-500 hover:bg-green-600 text-white font-bold px-4 py-2 rounded-xl text-sm text-center transition-colors">
									✅ Confirmar
								</a>
							{% endif %}
							{% if cita.estado != 'Cancelada' %}
								<a href="{{ path('app_admin_cita_cancelar', {'id': cita.id}) }}" onclick="return confirm('¿Seguro que quieres cancelar esta cita?')" class="bg-red-500 hover:bg-red-600 text-white font-bold px-4 py-2 rounded-xl text-sm text-center transition-colors">
									❌ Cancelar
								</a>
							{% endif %}
						</div>
					</div>
				</div>
			{% else %}
				<div class="p-8 text-center text-gray-500 text-lg">
					No hay citas programadas. ¡A captar clientes!
				</div>
			{% endfor %}
		</div>

		{# --- Versión escritorio: tabla --- #}
		<div class="hidden md:block overflow-x-auto">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="text-gray-400 text-xs uppercase bg-white border-b border-gray-100">
						<th class="px-6 py-4 font-semibold">Cliente</th>
						<th class="px-6 py-4 font-semibold">Servicio</th>
						<th class="px-6 py-4 font-semibold">Hora</th>
						<th class="px-6 py-4 font-semibold">Estado</th>
						<th class="px-6 py-4 font-semibold text-right">Acciones</th>
					</tr>
				</thead>
				<tbody class="text-sm text-gray-700">
					{% for cita in citas|slice(0, 5) %}
						<tr class="border-b border-gray-50 hover:bg-gray-50 transition">
							<td class="px-6 py-4">
								<a href="{{ path('app_admin_cliente_ficha', {'id': cita.usuario.id}) }}" class="font-bold text-gray-900 hover:text-pink-600 transition text-base">
									{{ cita.usuario.nombre }}
								</a>
								<span class="block text-xs text-gray-500 mt-0.5">{{ cita.usuario.email }}</span>
								{% if cita.usuario.telefono %}
									<span class="block text-xs font-semibold text-pink-600 mt-0.5">📞
										{{ cita.usuario.telefono }}</span>
								{% endif %}
							</td>
							<td class="px-6 py-4 font-semibold text-gray-800">
								{% for servicio in cita.servicios %}
									{{ servicio.nombre }}
									{% if not loop.last %}
										+
									{% endif %}
								{% else %}
									Cita General
								{% endfor %}
							</td>
							<td class="px-6 py-4 font-bold text-pink-600 text-base">
								{{ cita.fechaInicio|date('d/m/Y') }}<br>
								<span class="text-gray-500 text-sm font-semibold">{{ cita.fechaInicio|date('H:i') }}</span>
							</td>
							<td class="px-6 py-4">
								{% if cita.estado == 'Pendiente' %}
									<span class="px-3 py-1.5 bg-yellow-100 text-yellow-800 rounded-full text-sm font-bold">⏳ Pendiente</span>
								{% elseif cita.estado == 'Confirmada' %}
									<span class="px-3 py-1.5 bg-green-100 text-green-800 rounded-full text-sm font-bold">✅ Confirmada</span>
								{% else %}
									<span class="px-3 py-1.5 bg-red-100 text-red-800 rounded-full text-sm font-bold">❌ Cancelada</span>
								{% endif %}
							</td>
							<td class="px-6 py-4 text-right">
								<div class="flex justify-end gap-2">
									{% if cita.estado == 'Pendiente' %}
										<a href="{{ path('app_admin_cita_confirmar', {'id': cita.id}) }}" class="bg-green-50 hover:bg-green-500 hover:text-white text-green-700 font-bold px-4 py-2 rounded-xl border border-green-200 transition-colors text-sm">
											✅ Confirmar
										</a>
									{% endif %}
									{% if cita.estado != 'Cancelada' %}
										<a href="{{ path('app_admin_cita_cancelar', {'id': cita.id}) }}" onclick="return confirm('¿Seguro que quieres cancelar esta cita?')" class="bg-red-50 hover:bg-red-500 hover:text-white text-red-700 font-bold px-4 py-2 rounded-xl border border-red-200 transition-colors text-sm">
											❌ Cancelar
										</a>
									{% endif %}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="px-6 py-10 text-center text-gray-500 text-lg">
								No hay citas programadas. ¡A captar clientes!
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>

	{# ===== SEPARADOR ===== #}
	<div class="mt-14 mb-6 border-t border-gray-200 pt-10">
		<h2 class="text-2xl font-extrabold text-gray-900">⚙️ Configuración del Negocio</h2>
		<p class="text-gray-400 text-base mt-1">Gestiona cuándo y cómo se pueden hacer reservas.</p>
	</div>

	{# ===== 1. HORARIO BASE ===== #}
	<div id="horario" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
		<div class="flex items-center gap-4 p-6 border-b border-gray-100 bg-gray-50">
			<span class="text-3xl">🕐</span>
			<div>
				<h2 class="text-xl font-extrabold text-gray-900">Horario de Trabajo</h2>
				<p class="text-gray-400 text-sm mt-0.5">Las franjas en las que se aceptan reservas. Puedes tener varias (mañana y tarde).</p>
			</div>
		</div>
		<div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">➕ Añadir franja horaria</h3>
				<form method="POST" action="{{ path('admin_horario_nuevo') }}" class="flex flex-col gap-4">
					<div class="grid grid-cols-2 gap-4">
						<div>
							<label class="block text-sm font-bold text-gray-600 mb-2">Apertura</label>
							<input type="time" name="hora_apertura" required class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
						</div>
						<div>
							<label class="block text-sm font-bold text-gray-600 mb-2">Cierre</label>
							<input type="time" name="hora_cierre" required class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
						</div>
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Intervalo entre citas</label>
						<select name="intervalo" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							<option value="15">Cada 15 minutos</option>
							<option value="30" selected>Cada 30 minutos</option>
							<option value="60">Cada hora</option>
						</select>
					</div>
					<button type="submit" class="bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-6 rounded-xl shadow-sm transition-colors text-base">
						Guardar franja
					</button>
				</form>
			</div>

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">📋 Franjas activas</h3>
				{% if horarios is empty %}
					<div class="flex items-start gap-3 bg-red-50 border-2 border-red-200 rounded-xl p-5">
						<span class="text-2xl">⚠️</span>
						<p class="text-red-600 text-base font-bold">Sin franjas configuradas — los clientes no verán horas disponibles.</p>
					</div>
				{% else %}
					<ul class="flex flex-col gap-3">
						{% for horario in horarios %}
							<li class="flex items-center justify-between bg-green-50 border border-green-100 rounded-xl px-5 py-4">
								<div class="flex items-center gap-3">
									<span class="text-xl">🟢</span>
									<div>
										<span class="font-extrabold text-gray-800 text-base">
											{{ horario.horaApertura|date('H:i') }}
											–
											{{ horario.horaCierre|date('H:i') }}
										</span>
										<span class="ml-2 text-sm text-gray-500">cada
											{{ horario.intervaloMinutos }}
											min</span>
									</div>
								</div>
								<a href="{{ path('admin_horario_eliminar', {'id': horario.id}) }}" onclick="return confirm('¿Eliminar esta franja horaria?')" class="bg-red-100 hover:bg-red-500 hover:text-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm transition-colors">
									🗑️ Eliminar
								</a>
							</li>
						{% endfor %}
					</ul>
				{% endif %}
			</div>
		</div>
	</div>

	{# ===== 2. REGLAS RECURRENTES ===== #}
	<div id="reglas" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
		<div class="flex items-center gap-4 p-6 border-b border-gray-100 bg-gray-50">
			<span class="text-3xl">📋</span>
			<div>
				<h2 class="text-xl font-extrabold text-gray-900">Reglas de Horario</h2>
				<p class="text-gray-400 text-sm mt-0.5">Días o franjas que
					<strong>siempre</strong>
					están cerrados. Ej: domingos, tardes de sábado.</p>
			</div>
		</div>
		<div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">➕ Añadir regla recurrente</h3>
				<form method="POST" action="{{ path('admin_regla_horario_nueva') }}" class="flex flex-col gap-4">
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Día de la semana</label>
						<select name="dia_semana" required class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							<option value="1">Lunes</option>
							<option value="2">Martes</option>
							<option value="3">Miércoles</option>
							<option value="4">Jueves</option>
							<option value="5">Viernes</option>
							<option value="6">Sábado</option>
							<option value="0">Domingo</option>
						</select>
					</div>

					<label class="flex items-center gap-3 bg-gray-50 border-2 border-gray-200 rounded-xl px-4 py-3 cursor-pointer hover:border-pink-300 transition-colors">
						<input type="checkbox" id="toggle-franja" class="w-5 h-5 rounded accent-pink-600">
						<span class="text-base text-gray-700 font-semibold">Solo bloquear una franja horaria (no el día entero)</span>
					</label>

					<div id="bloque-franja" class="hidden flex flex-col gap-3">
						<div class="grid grid-cols-2 gap-4">
							<div>
								<label class="block text-sm font-bold text-gray-600 mb-2">Desde</label>
								<input type="time" name="hora_desde" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							</div>
							<div>
								<label class="block text-sm font-bold text-gray-600 mb-2">Hasta</label>
								<input type="time" name="hora_hasta" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
							</div>
						</div>
					</div>

					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">
							Motivo
							<span class="font-normal text-gray-400">(opcional)</span>
						</label>
						<input type="text" name="motivo" placeholder="Ej: Domingo cerrado" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
					</div>

					<button type="submit" class="bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-6 rounded-xl shadow-sm transition-colors text-base">
						Guardar regla
					</button>
				</form>
			</div>

			<div>
				{% set dias = {0: 'Domingo', 1: 'Lunes', 2: 'Martes', 3: 'Miércoles', 4: 'Jueves', 5: 'Viernes', 6: 'Sábado'} %}
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">📋 Reglas activas</h3>
				{% if reglasHorario is empty %}
					<p class="text-gray-400 text-base py-4">No hay reglas configuradas.</p>
				{% else %}
					<ul class="flex flex-col gap-3">
						{% for regla in reglasHorario %}
							<li class="flex items-center justify-between bg-gray-50 border border-gray-200 rounded-xl px-5 py-4">
								<div class="flex items-start gap-3">
									<span class="text-xl mt-0.5">🔁</span>
									<div>
										<span class="font-extrabold text-gray-800 text-base">{{ dias[regla.diaSemana] }}</span>
										{% if regla.horaDesde and regla.horaHasta %}
											<span class="ml-2 text-sm text-pink-600 font-bold">
												{{ regla.horaDesde|date('H:i') }}
												–
												{{ regla.horaHasta|date('H:i') }}
											</span>
										{% else %}
											<span class="ml-2 text-sm bg-red-100 text-red-600 font-bold px-2 py-0.5 rounded-full">
												Día completo
											</span>
										{% endif %}
										{% if regla.motivo %}
											<p class="text-sm text-gray-400 mt-0.5">{{ regla.motivo }}</p>
										{% endif %}
									</div>
								</div>
								<a href="{{ path('admin_regla_horario_eliminar', {'id': regla.id}) }}" onclick="return confirm('¿Eliminar esta regla?')" class="bg-red-100 hover:bg-red-500 hover:text-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm transition-colors shrink-0 ml-3">
									🗑️ Eliminar
								</a>
							</li>
						{% endfor %}
					</ul>
				{% endif %}
			</div>
		</div>
	</div>

	{# ===== 3. DÍAS BLOQUEADOS PUNTUALES ===== #}
	<div id="bloqueados" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-10">
		<div class="flex items-center gap-4 p-6 border-b border-gray-100 bg-gray-50">
			<span class="text-3xl">🚫</span>
			<div>
				<h2 class="text-xl font-extrabold text-gray-900">Días Bloqueados</h2>
				<p class="text-gray-400 text-sm mt-0.5">Fechas concretas cerradas. Ej: festivos, vacaciones, enfermedad.</p>
			</div>
		</div>
		<div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">➕ Bloquear una fecha</h3>
				<form method="POST" action="{{ path('admin_dias_bloqueados') }}" class="flex flex-col gap-4">
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Fecha</label>
						<input type="date" name="fecha" required min="{{ "now"|date('Y-m-d') }}" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">
							Motivo
							<span class="font-normal text-gray-400">(opcional)</span>
						</label>
						<input type="text" name="motivo" placeholder="Ej: Vacaciones de agosto" class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400">
					</div>
					<button type="submit" class="bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-6 rounded-xl shadow-sm transition-colors text-base">
						Bloquear día
					</button>
				</form>
			</div>

			<div>
				<h3 class="font-extrabold text-gray-700 text-base uppercase tracking-wide mb-5">📋 Próximos días bloqueados</h3>
				{% if diasBloqueados is empty %}
					<p class="text-gray-400 text-base py-4">No hay días bloqueados.</p>
				{% else %}
					<ul class="flex flex-col gap-3">
						{% for dia in diasBloqueados %}
							<li class="flex items-center justify-between bg-red-50 border border-red-100 rounded-xl px-5 py-4">
								<div class="flex items-center gap-3">
									<span class="text-xl">📵</span>
									<div>
										<span class="font-extrabold text-gray-800 text-base">{{ dia.fecha|date('d/m/Y') }}</span>
										{% if dia.motivo %}
											<p class="text-sm text-gray-500 mt-0.5">{{ dia.motivo }}</p>
										{% endif %}
									</div>
								</div>
								<a href="{{ path('admin_dias_bloqueados_eliminar', {'id': dia.id}) }}" onclick="return confirm('¿Eliminar este día bloqueado?')" class="bg-red-100 hover:bg-red-500 hover:text-white text-red-600 font-bold px-4 py-2 rounded-xl text-sm transition-colors shrink-0 ml-3">
									🗑️ Eliminar
								</a>
							</li>
						{% endfor %}
					</ul>
				{% endif %}
			</div>
		</div>
	</div>

	<script>
		document.getElementById('toggle-franja').addEventListener('change', function () {
document.getElementById('bloque-franja').classList.toggle('hidden', !this.checked);
});

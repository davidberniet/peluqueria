{% extends 'admin/base.html.twig' %}

{% block title %}Panel de Control | Venus
{% endblock %}

{% block admin_content %}

	{# iOS/Safari renderiza los <input type="time"> con appearance nativo que ignora el ancho
	   y los colapsa. Reseteamos el appearance, fijamos altura y alineamos el valor a la izquierda. #}
	<style>
		input[type="time"] {
			-webkit-appearance: none;
			appearance: none;
			min-height: 52px;
		}
		input[type="time"]::-webkit-date-and-time-value {
			text-align: left;
		}
	</style>

	{# ===== CABECERA ===== #}
	<div class="mb-8">
		<h1 class="text-3xl font-extrabold text-gray-900">Panel de Control</h1>
		<p class="text-gray-500 mt-1">Bienvenido, Jefe. Aquí tienes el resumen de las citas.</p>
	</div>

	{# ===== FLASH MESSAGES ===== #}
	{% for msg in app.flashes('success') %}
		<div class="mb-6 bg-green-50 border border-green-200 text-green-700 font-semibold px-5 py-4 rounded-xl">{{ msg }}</div>
	{% endfor %}
	{% for msg in app.flashes('error') %}
		<div class="mb-6 bg-red-50 border border-red-200 text-red-700 font-semibold px-5 py-4 rounded-xl">{{ msg }}</div>
	{% endfor %}

	{# ===== TARJETAS DE ESTADÍSTICAS ===== #}
	<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
		<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
			<div class="bg-pink-100 p-4 rounded-xl shrink-0 flex items-center justify-center w-16 h-16">
				<svg class="w-8 h-8 text-pink-600" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
				</svg>
			</div>
			<div>
				<p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Citas Hoy</p>
				<p class="text-4xl font-extrabold text-gray-900">{{ citas_hoy }}</p>
			</div>
		</div>
		<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
			<div class="bg-green-100 p-4 rounded-xl shrink-0 flex items-center justify-center w-16 h-16">
				<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
				</svg>
			</div>
			<div>
				<p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Ingresos Hoy</p>
				<p class="text-4xl font-extrabold text-gray-900">{{ ingresos_hoy }}€</p>
			</div>
		</div>
		<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex items-center gap-4">
			<div class="bg-blue-100 p-4 rounded-xl shrink-0 flex items-center justify-center w-16 h-16">
				<svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
				</svg>
			</div>
			<div>
				<p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Clientes</p>
				<p class="text-4xl font-extrabold text-gray-900">{{ total_clientes }}</p>
			</div>
		</div>
	</div>

	{# ===== PRÓXIMAS CITAS ===== #}
	<div id="citas" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
		<div class="flex justify-between items-center p-6 border-b border-gray-100 bg-gray-50">
			<div>
				<h2 class="text-lg font-semibold text-gray-900">Próximas citas</h2>
				<p class="text-gray-400 text-xs mt-0.5">Las 5 más cercanas</p>
			</div>
			<a href="{{ path('app_admin_citas') }}" class="bg-gray-900 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-colors text-xs">
				Ver todas
			</a>
		</div>

		{# --- Versión móvil: tarjetas --- #}
		{% set proximas_citas = citas|filter(c => c.estado != 'Cancelada' and c.fechaInicio > date()) %}
		<div class="block md:hidden divide-y divide-gray-100">
			{% for cita in proximas_citas|slice(0, 5) %}
				<div class="p-5">
					<div class="flex justify-between items-start mb-3">
						<div>
							<a href="{{ path('app_admin_cliente_ficha', {'id': cita.usuario.id}) }}" class="font-extrabold text-gray-900 text-lg hover:text-pink-600 transition">
								{{ cita.usuario.nombre }}
							</a>
							<p class="text-sm text-gray-500">{{ cita.usuario.email }}</p>
							{% if cita.usuario.telefono %}
								<p class="text-sm font-bold text-pink-600 mt-1">📞
									{{ cita.usuario.telefono }}</p>
							{% endif %}
						</div>
						<div class="text-right">
							<p class="font-extrabold text-pink-600 text-lg">{{ cita.fechaInicio|date('H:i') }}</p>
							<p class="text-sm text-gray-500">{{ cita.fechaInicio|date('d/m/Y') }}</p>
						</div>
					</div>
					<div class="flex justify-between items-center">
						<div>
							<p class="text-sm text-gray-700 font-semibold mb-2">
								{% for servicio in cita.servicios %}
									{{ servicio.nombre }}
									{% if not loop.last %}
										+
									{% endif %}
								{% else %}
									Cita General
								{% endfor %}
							</p>
							{% if cita.estado != 'Cancelada' and cita.fechaInicio < date() %}
								<span class="px-3 py-1.5 bg-gray-100 text-gray-800 rounded-full text-sm font-bold">
									Completada</span>
							{% elseif cita.estado == 'Pendiente' %}
								<span class="px-3 py-1.5 bg-yellow-100 text-yellow-800 rounded-full text-sm font-bold">Pendiente</span>
							{% elseif cita.estado == 'Confirmada' %}
								<span class="px-3 py-1.5 bg-green-100 text-green-800 rounded-full text-sm font-bold">Confirmada</span>
							{% else %}
								<span class="px-3 py-1.5 bg-red-100 text-red-800 rounded-full text-sm font-bold">Cancelada</span>
							{% endif %}
						</div>
						<div class="flex flex-col gap-2">
							{% if cita.estado == 'Pendiente' and cita.fechaInicio > date() %}
								<a href="{{ path('app_admin_cita_confirmar', {'id': cita.id}) }}" class="bg-green-500 hover:bg-green-600 text-white font-bold px-4 py-2 rounded-xl text-sm text-center transition-colors">
									Confirmar
								</a>
							{% endif %}
							{% if cita.estado != 'Cancelada' and cita.fechaInicio > date() %}
								<a href="{{ path('app_admin_cita_cancelar', {'id': cita.id}) }}" onclick="return confirm('¿Seguro que quieres cancelar esta cita?')" class="bg-red-500 hover:bg-red-600 text-white font-bold px-4 py-2 rounded-xl text-sm text-center transition-colors">
									Cancelar
								</a>
							{% endif %}
						</div>
					</div>
				</div>
			{% else %}
				<div class="p-8 text-center text-gray-500 text-lg">
					No hay citas programadas. ¡A captar clientes!
				</div>
			{% endfor %}
		</div>

		{# --- Versión escritorio: tabla --- #}
		<div class="hidden md:block overflow-x-auto">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="text-gray-400 text-xs uppercase bg-white border-b border-gray-100">
						<th class="px-6 py-4 font-semibold">Cliente</th>
						<th class="px-6 py-4 font-semibold">Servicio</th>
						<th class="px-6 py-4 font-semibold">Hora</th>
						<th class="px-6 py-4 font-semibold">Estado</th>
						<th class="px-6 py-4 font-semibold text-right">Acciones</th>
					</tr>
				</thead>
				<tbody class="text-sm text-gray-700">
					{% for cita in proximas_citas|slice(0, 5) %}
						<tr class="border-b border-gray-50 hover:bg-gray-50 transition">
							<td class="px-6 py-4">
								<a href="{{ path('app_admin_cliente_ficha', {'id': cita.usuario.id}) }}" class="font-bold text-gray-900 hover:text-pink-600 transition text-base">
									{{ cita.usuario.nombre }}
								</a>
								<span class="block text-xs text-gray-500 mt-0.5">{{ cita.usuario.email }}</span>
								{% if cita.usuario.telefono %}
									<span class="block text-xs font-semibold text-pink-600 mt-0.5">📞
										{{ cita.usuario.telefono }}</span>
								{% endif %}
							</td>
							<td class="px-6 py-4 font-semibold text-gray-800">
								{% for servicio in cita.servicios %}
									{{ servicio.nombre }}
									{% if not loop.last %}
										+
									{% endif %}
								{% else %}
									Cita General
								{% endfor %}
							</td>
							<td class="px-6 py-4 font-bold text-pink-600 text-base">
								{{ cita.fechaInicio|date('d/m/Y') }}<br>
								<span class="text-gray-500 text-sm font-semibold">{{ cita.fechaInicio|date('H:i') }}</span>
							</td>
							<td class="px-6 py-4">
								{% if cita.estado != 'Cancelada' and cita.fechaInicio < date() %}
									<span class="px-3 py-1.5 bg-gray-100 text-gray-800 rounded-full text-sm font-bold">Completada</span>
								{% elseif cita.estado == 'Pendiente' %}
									<span class="px-3 py-1.5 bg-yellow-100 text-yellow-800 rounded-full text-sm font-bold">Pendiente</span>
								{% elseif cita.estado == 'Confirmada' %}
									<span class="px-3 py-1.5 bg-green-100 text-green-800 rounded-full text-sm font-bold">Confirmada</span>
								{% else %}
									<span class="px-3 py-1.5 bg-red-100 text-red-800 rounded-full text-sm font-bold">Cancelada</span>
								{% endif %}
							</td>
							<td class="px-6 py-4 text-right">
								<div class="flex justify-end gap-2">
									{% if cita.estado == 'Pendiente' and cita.fechaInicio > date() %}
										<a href="{{ path('app_admin_cita_confirmar', {'id': cita.id}) }}" class="bg-green-50 hover:bg-green-500 hover:text-white text-green-700 font-bold px-4 py-2 rounded-xl border border-green-200 transition-colors text-sm">
											Confirmar
										</a>
									{% endif %}
									{% if cita.estado != 'Cancelada' and cita.fechaInicio > date() %}
										<a href="{{ path('app_admin_cita_cancelar', {'id': cita.id}) }}" onclick="return confirm('¿Seguro que quieres cancelar esta cita?')" class="bg-red-50 hover:bg-red-500 hover:text-white text-red-700 font-bold px-4 py-2 rounded-xl border border-red-200 transition-colors text-sm">
											Cancelar
										</a>
									{% endif %}
								</div>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="px-6 py-10 text-center text-gray-500 text-lg">
								No hay citas programadas. ¡A captar clientes!
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>


{% endblock %}

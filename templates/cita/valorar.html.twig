{% extends 'base.html.twig' %}

{% block title %}Valorar Cita | Venus{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[70vh] py-10">
    <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl w-full max-w-lg border border-gray-100">
        
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Valora tu experiencia</h1>
            <p class="text-gray-500">¿Qué tal fue tu cita el {{ cita.fechaInicio|date('d/m/Y') }}?</p>
        </div>

        <form method="post" action="{{ path('app_cita_valorar', {'id': cita.id}) }}" class="space-y-6">
            
            <div class="text-center">
                <label class="block text-sm font-bold text-gray-700 mb-4 uppercase tracking-wider">Tu puntuación</label>
                <div class="flex justify-center gap-2 flex-row-reverse rating-container">
                    <input type="radio" id="star5" name="estrellas" value="5" class="hidden peer/5" required />
                    <label for="star5" class="text-4xl text-gray-300 peer-checked/5:text-yellow-400 hover:text-yellow-400 peer-hover/5:text-yellow-400 cursor-pointer transition-colors duration-200">★</label>

                    <input type="radio" id="star4" name="estrellas" value="4" class="hidden peer/4" />
                    <label for="star4" class="text-4xl text-gray-300 peer-checked/4:text-yellow-400 peer-checked/5:text-yellow-400 hover:text-yellow-400 peer-hover/4:text-yellow-400 peer-hover/5:text-yellow-400 cursor-pointer transition-colors duration-200">★</label>

                    <input type="radio" id="star3" name="estrellas" value="3" class="hidden peer/3" />
                    <label for="star3" class="text-4xl text-gray-300 peer-checked/3:text-yellow-400 peer-checked/4:text-yellow-400 peer-checked/5:text-yellow-400 hover:text-yellow-400 peer-hover/3:text-yellow-400 peer-hover/4:text-yellow-400 peer-hover/5:text-yellow-400 cursor-pointer transition-colors duration-200">★</label>

                    <input type="radio" id="star2" name="estrellas" value="2" class="hidden peer/2" />
                    <label for="star2" class="text-4xl text-gray-300 peer-checked/2:text-yellow-400 peer-checked/3:text-yellow-400 peer-checked/4:text-yellow-400 peer-checked/5:text-yellow-400 hover:text-yellow-400 peer-hover/2:text-yellow-400 peer-hover/3:text-yellow-400 peer-hover/4:text-yellow-400 peer-hover/5:text-yellow-400 cursor-pointer transition-colors duration-200">★</label>

                    <input type="radio" id="star1" name="estrellas" value="1" class="hidden peer/1" />
                    <label for="star1" class="text-4xl text-gray-300 peer-checked/1:text-yellow-400 peer-checked/2:text-yellow-400 peer-checked/3:text-yellow-400 peer-checked/4:text-yellow-400 peer-checked/5:text-yellow-400 hover:text-yellow-400 peer-hover/1:text-yellow-400 peer-hover/2:text-yellow-400 peer-hover/3:text-yellow-400 peer-hover/4:text-yellow-400 peer-hover/5:text-yellow-400 cursor-pointer transition-colors duration-200">★</label>
                </div>
            </div>

            <div>
                <label for="comentario" class="block text-sm font-bold text-gray-700 mb-2">Cuéntanos más (opcional)</label>
                <textarea name="comentario" id="comentario" rows="4" 
                          class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white resize-none" 
                          placeholder="¿Qué fue lo que más te gustó?"></textarea>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 pt-4">
                <a href="{{ path('app_cliente_perfil') }}#historial" class="w-full sm:w-1/3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3.5 px-4 rounded-xl text-center transition-colors">
                    Cancelar
                </a>
                <button type="submit" class="w-full sm:w-2/3 bg-pink-600 hover:bg-pink-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-md transition-all">
                    Enviar valoración
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    /* Efecto hover acumulativo para estrellas con flex-row-reverse */
    .rating-container label:hover,
    .rating-container label:hover ~ label {
        color: #facc15 !important;
    }
</style>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Reservar {{ servicio.nombre }} | Venus{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 py-8">

	{# ===== CABECERA ===== #}
	<div class="flex items-center gap-4 mb-8">
		<a href="{{ path('app_reservar', {'id': servicio.id}) }}"
		   class="flex items-center justify-center w-9 h-9 rounded-xl bg-white border border-gray-200 text-gray-500 hover:text-pink-600 hover:border-pink-300 transition-colors shadow-sm shrink-0">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
			</svg>
		</a>
		<div>
			<h1 class="text-2xl font-extrabold text-gray-900 leading-tight">Elige fecha y hora</h1>
			<p class="text-gray-400 text-sm mt-0.5">{{ local.nombre }}</p>
		</div>
	</div>

	{# Flash de error (solapamiento de cita) #}
	{% for msg in app.flashes('error') %}
		<div class="mb-6 bg-red-50 border border-red-200 text-red-700 font-semibold px-5 py-4 rounded-xl text-sm">
			{{ msg }}
		</div>
	{% endfor %}

	{# ===== LAYOUT DOS COLUMNAS ===== #}
	<div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-5">

		{# ─── COLUMNA IZQUIERDA ─── #}
		<div class="flex flex-col gap-5">

			{# Calendario #}
			<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 sm:p-6">

				{# Navegación de mes #}
				<div class="flex items-center justify-between mb-5">
					<button id="prev-mes" type="button" disabled
							class="flex items-center justify-center w-9 h-9 rounded-xl text-gray-300 cursor-not-allowed transition-colors">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
						</svg>
					</button>
					<h2 id="mes-label" class="font-extrabold text-gray-900 text-lg tracking-wide"></h2>
					<button id="next-mes" type="button"
							class="flex items-center justify-center w-9 h-9 rounded-xl text-gray-600 hover:bg-pink-50 hover:text-pink-600 transition-colors">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
						</svg>
					</button>
				</div>

				{# Cabeceras día de la semana #}
				<div class="grid grid-cols-7 mb-2">
					{% for d in ['L','M','X','J','V','S','D'] %}
						<div class="text-center text-xs font-bold text-gray-400 py-1.5">{{ d }}</div>
					{% endfor %}
				</div>

				{# Cuadrícula de días (JS) #}
				<div id="grid-dias" class="grid grid-cols-7 gap-1 sm:gap-1.5"></div>

				{# Leyenda #}
				<div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-5 text-xs text-gray-400">
					<span class="flex items-center gap-1.5">
						<span class="w-2.5 h-2.5 rounded-full ring-2 ring-pink-400 inline-block"></span>Hoy
					</span>
					<span class="flex items-center gap-1.5">
						<span class="w-2.5 h-2.5 rounded-full bg-pink-600 inline-block"></span>Seleccionado
					</span>
					<span class="flex items-center gap-1.5">
						<span class="w-2.5 h-2.5 rounded-full bg-gray-200 inline-block"></span>No disponible
					</span>
				</div>
			</div>

			{# Horas disponibles #}
			<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
				<div class="px-5 py-4 border-b border-gray-100 bg-gray-50/80">
					<p id="horas-titulo" class="text-sm font-bold text-gray-500">
						Selecciona un día para ver los horarios disponibles
					</p>
				</div>
				<div id="contenedor-horas"
					 class="p-5 flex flex-wrap gap-2 min-h-[72px] items-start content-start">
					{# Rellenado por JS #}
				</div>
			</div>

		</div>

		{# ─── COLUMNA DERECHA (sticky en desktop) ─── #}
		<div class="lg:sticky lg:top-6 lg:self-start">
			<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

				{# Fecha/hora seleccionada #}
				<div class="p-5 bg-gradient-to-br from-pink-50 to-white border-b border-pink-100/60">
					<p class="text-xs font-bold text-pink-400 uppercase tracking-wider mb-2">Tu cita</p>
					<p id="resumen-hora" class="text-lg font-extrabold text-gray-800 leading-snug">
						Selecciona fecha y hora
					</p>
				</div>

				{# Servicios y total #}
				<div class="p-5 border-b border-gray-100">
					<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Servicios</p>
					<ul class="space-y-2">
						{% for s in serviciosSeleccionados %}
						<li class="flex items-center justify-between text-sm">
							<span class="text-gray-700 flex items-center gap-2">
								<span class="w-1.5 h-1.5 bg-pink-400 rounded-full shrink-0"></span>
								{{ s.nombre }}
							</span>
							<span class="font-bold text-gray-800 ml-3 shrink-0">{{ s.precio|number_format(2, ',', '.') }}€</span>
						</li>
						{% endfor %}
					</ul>
					<div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
						<span class="text-xs text-gray-400">⏱ {{ duracionTotal }} min</span>
						<span class="text-2xl font-extrabold text-gray-900">{{ precioTotal|number_format(2, ',', '.') }}€</span>
					</div>
				</div>

				{# Formulario #}
				<div class="p-5">

					{{ form_start(form, {'attr': {'class': 'flex flex-col gap-5', 'id': 'form-reserva'}}) }}

					{% if not form.vars.valid %}
						<div class="bg-red-50 text-red-600 p-3 rounded-xl text-sm border border-red-200">
							<ul class="space-y-1">
							{% for child in form %}
								{% for error in child.vars.errors %}
									<li>{{ error.message }}</li>
								{% endfor %}
							{% endfor %}
							</ul>
						</div>
					{% endif %}

					{# Campos ocultos #}
					<div class="hidden">
						<input type="hidden" id="cita_fechaInicio" name="cita[fechaInicio]" value="">
						{{ form_widget(form.notas) }}
					</div>

					{# Empleado #}
					<div>
						<label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">¿Con quién?</label>
						{{ form_widget(form.empleado) }}
						<p class="text-xs text-gray-400 mt-1.5">Deja «Sin preferencia» para asignación automática.</p>
					</div>

					{# Botón de reserva #}
					<button type="button" id="btn-submit-fake"
							class="w-full bg-gray-100 text-gray-400 font-bold py-3.5 px-6 rounded-xl cursor-not-allowed text-sm transition-colors">
						Elige fecha y hora primero
					</button>
					<button type="submit" id="btn-submit-real"
							class="hidden w-full bg-pink-600 hover:bg-pink-700 text-white font-extrabold py-3.5 px-6 rounded-xl shadow-md hover:shadow-pink-500/30 transition-all text-sm">
						Confirmar reserva →
					</button>

					{{ form_end(form) }}
				</div>

			</div>
		</div>

	</div>
</div>

<script>
// ===== DATOS =====
const horasOcupadas  = {{ horasOcupadas|default('{}')|raw }};
const diasBloqueados = {{ diasBloqueados|default('[]')|raw }};
const horasTotales   = {{ slotsTotales|raw }};
const reglasHorario  = {{ reglasHorario|default('[]')|raw }};

// ===== ESTADO =====
const hoy      = new Date();
const todayStr = hoy.getFullYear() + '-' + String(hoy.getMonth()+1).padStart(2,'0') + '-' + String(hoy.getDate()).padStart(2,'0');
let selectedDate = null;
let selectedTime = null;
let currentYear  = hoy.getFullYear();
let currentMonth = hoy.getMonth();

const MAX_MESES = 3;
const MESES     = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const DIAS_ES   = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];

// ===== REGLAS =====
function diaSemanaBloqueadoPorRegla(f) {
	const d = new Date(f + 'T12:00:00').getDay();
	return reglasHorario.some(r => r.dia === d && r.desde === null);
}
function horaBloquedaPorRegla(f, hora) {
	const d = new Date(f + 'T12:00:00').getDay();
	return reglasHorario.some(r => {
		if (r.dia !== d || r.desde === null) return false;
		return hora >= r.desde && hora < r.hasta;
	});
}

// ===== CALENDARIO =====
function renderCalendario() {
	document.getElementById('mes-label').textContent = MESES[currentMonth] + ' ' + currentYear;

	const hoyDate   = new Date(todayStr + 'T12:00:00');
	const totalDias = new Date(currentYear, currentMonth + 1, 0).getDate();
	let offset      = new Date(currentYear, currentMonth, 1).getDay();
	offset = offset === 0 ? 6 : offset - 1; // Lun = 0

	const grid = document.getElementById('grid-dias');
	grid.innerHTML = '';

	for (let i = 0; i < offset; i++) grid.appendChild(document.createElement('div'));

	for (let dia = 1; dia <= totalDias; dia++) {
		const m     = String(currentMonth + 1).padStart(2, '0');
		const d     = String(dia).padStart(2, '0');
		const fecha = `${currentYear}-${m}-${d}`;
		const fDate = new Date(fecha + 'T12:00:00');

		const esPasado    = fDate < hoyDate;
		const esBloqueado = !esPasado && (diasBloqueados.includes(fecha) || diaSemanaBloqueadoPorRegla(fecha));
		const esHoy       = fecha === todayStr;
		const esSeleccion = fecha === selectedDate;
		const disponible  = !esPasado && !esBloqueado;

		const btn = document.createElement('button');
		btn.type = 'button';
		btn.textContent = dia;
		btn.dataset.fecha = fecha;

		let cls = 'w-full aspect-square flex items-center justify-center rounded-xl text-sm font-bold transition-all select-none focus:outline-none ';

		if (esPasado) {
			cls += 'text-gray-200 cursor-not-allowed';
			btn.disabled = true;
		} else if (esBloqueado) {
			cls += 'text-gray-300 line-through bg-gray-50/50 cursor-not-allowed';
			btn.disabled = true;
			btn.title = 'No disponible';
		} else if (esSeleccion) {
			cls += 'bg-pink-600 text-white shadow-md shadow-pink-200 scale-110 z-10 relative';
		} else if (esHoy) {
			cls += 'ring-2 ring-pink-400 ring-offset-1 text-pink-700 hover:bg-pink-50 cursor-pointer';
		} else {
			cls += 'text-gray-700 hover:bg-pink-50 hover:text-pink-600 cursor-pointer';
		}

		btn.className = cls;

		if (disponible) {
			btn.addEventListener('click', function () {
				selectedDate = this.dataset.fecha;
				selectedTime = null;
				comprobarYActualizar();
				renderCalendario();
				renderizarHorasDisponibles(selectedDate);
			});
		}

		grid.appendChild(btn);
	}

	// Botones de navegación
	const prevBtn  = document.getElementById('prev-mes');
	const enInicio = currentYear === hoy.getFullYear() && currentMonth === hoy.getMonth();
	prevBtn.disabled  = enInicio;
	prevBtn.className = 'flex items-center justify-center w-9 h-9 rounded-xl transition-colors ' +
		(enInicio ? 'text-gray-300 cursor-not-allowed' : 'text-gray-600 hover:bg-pink-50 hover:text-pink-600 cursor-pointer');

	const nextBtn = document.getElementById('next-mes');
	let limY = hoy.getFullYear(), limM = hoy.getMonth() + MAX_MESES;
	if (limM > 11) { limM -= 12; limY++; }
	const enLimite = currentYear > limY || (currentYear === limY && currentMonth >= limM);
	nextBtn.disabled  = enLimite;
	nextBtn.className = 'flex items-center justify-center w-9 h-9 rounded-xl transition-colors ' +
		(enLimite ? 'text-gray-300 cursor-not-allowed' : 'text-gray-600 hover:bg-pink-50 hover:text-pink-600 cursor-pointer');
}

// ===== HORAS =====
function renderizarHorasDisponibles(fecha) {
	const contenedor = document.getElementById('contenedor-horas');
	const titulo     = document.getElementById('horas-titulo');
	contenedor.innerHTML = '';

	// Título contextual
	const fObj = new Date(fecha + 'T12:00:00');
	titulo.textContent = 'Horarios para el ' + DIAS_ES[fObj.getDay()] + ' ' + fObj.getDate() + ' de ' + MESES[fObj.getMonth()].toLowerCase();

	const ocupadas   = horasOcupadas[fecha] || [];
	const ahora      = new Date();
	const hAct       = ahora.getHours();
	const mAct       = ahora.getMinutes();
	let hayLibres    = false;

	horasTotales.forEach(hora => {
		if (fecha === todayStr) {
			const [h, m] = hora.split(':').map(Number);
			if (h < hAct || (h === hAct && m <= mAct)) return;
		}
		if (ocupadas.includes(hora) || horaBloquedaPorRegla(fecha, hora)) return;

		hayLibres = true;
		const btn = document.createElement('button');
		btn.type = 'button';
		btn.className = 'time-pill px-4 py-2 border border-gray-200 bg-white text-gray-700 rounded-xl cursor-pointer hover:border-pink-400 hover:text-pink-600 hover:bg-pink-50 font-semibold text-sm transition-all focus:outline-none';
		btn.dataset.time = hora;
		btn.textContent  = hora;

		btn.addEventListener('click', function () {
			document.querySelectorAll('.time-pill').forEach(p => {
				p.classList.remove('bg-pink-600', 'text-white', 'border-pink-600', 'shadow-md');
				p.classList.add('border-gray-200', 'text-gray-700', 'bg-white');
			});
			this.classList.remove('border-gray-200', 'text-gray-700', 'bg-white');
			this.classList.add('bg-pink-600', 'text-white', 'border-pink-600', 'shadow-md');
			selectedTime = this.dataset.time;
			comprobarYActualizar();
		});

		contenedor.appendChild(btn);
	});

	if (!hayLibres) {
		contenedor.innerHTML = '<p class="text-red-500 font-semibold text-sm py-1">No hay horas disponibles para este día.</p>';
	}
}

// ===== ACTUALIZAR RESUMEN Y BOTÓN =====
function comprobarYActualizar() {
	const inputFecha  = document.getElementById('cita_fechaInicio');
	const resumenHora = document.getElementById('resumen-hora');
	const btnFake     = document.getElementById('btn-submit-fake');
	const btnReal     = document.getElementById('btn-submit-real');

	if (selectedDate && selectedTime) {
		inputFecha.value = selectedDate + 'T' + selectedTime;
		const [y, mo, dd] = selectedDate.split('-');
		const fObj = new Date(selectedDate + 'T12:00:00');
		resumenHora.textContent = DIAS_ES[fObj.getDay()].charAt(0).toUpperCase() + DIAS_ES[fObj.getDay()].slice(1)
			+ ' ' + dd + ' de ' + MESES[fObj.getMonth()].toLowerCase() + ' · ' + selectedTime + 'h';
		btnFake.classList.add('hidden');
		btnReal.classList.remove('hidden');
	} else {
		inputFecha.value = '';
		resumenHora.textContent = 'Selecciona fecha y hora';
		btnFake.classList.remove('hidden');
		btnReal.classList.add('hidden');
	}
}

// ===== CAMBIO DE MES =====
function resetearSeleccionSiCambiaMes() {
	if (!selectedDate) return;
	const [sy, sm] = selectedDate.split('-').map(Number);
	if (sm - 1 !== currentMonth || sy !== currentYear) {
		selectedDate = null;
		selectedTime = null;
		comprobarYActualizar();
		document.getElementById('horas-titulo').textContent = 'Selecciona un día para ver los horarios disponibles';
		document.getElementById('contenedor-horas').innerHTML = '';
	}
}

// ===== INIT =====
document.addEventListener('DOMContentLoaded', function () {
	renderCalendario();

	document.getElementById('prev-mes').addEventListener('click', function () {
		if (this.disabled) return;
		if (--currentMonth < 0) { currentMonth = 11; currentYear--; }
		resetearSeleccionSiCambiaMes();
		renderCalendario();
	});

	document.getElementById('next-mes').addEventListener('click', function () {
		if (this.disabled) return;
		if (++currentMonth > 11) { currentMonth = 0; currentYear++; }
		resetearSeleccionSiCambiaMes();
		renderCalendario();
	});
});
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Elegir local | {{ servicio.nombre }} | Venus{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto my-10 px-4">
    <div class="text-center mb-8">
        <h2 class="text-3xl font-extrabold text-gray-900 mb-2">¿Dónde te apetece ir?</h2>
        <p class="text-gray-500">Selecciona el local para tu cita de <strong class="text-pink-600">{{ servicio.nombre }}</strong>.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {% for local in locales %}
            <a href="{{ path('app_seleccionar_servicios', {'localId': local.id, 'servicioId': servicio.id}) }}"
               class="block bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg hover:border-pink-300 transition-all duration-300 transform hover:-translate-y-1 group">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 rounded-full bg-pink-50 flex items-center justify-center shrink-0 group-hover:bg-pink-600 transition-colors">
                        <svg class="w-6 h-6 text-pink-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900 group-hover:text-pink-600 transition-colors mb-1">{{ local.nombre }}</h3>
                        <p class="text-gray-500 text-sm mb-3">{{ local.direccion }}, {{ local.ciudad }}</p>
                        
                        <div class="flex items-center gap-2 text-xs font-semibold text-gray-400">
                            <span class="bg-gray-100 px-2 py-1 rounded-md">
                                {{ local.empleados|length }} empleados disponibles
                            </span>
                        </div>
                    </div>
                </div>
            </a>
        {% else %}
            <div class="col-span-full bg-yellow-50 border border-yellow-200 text-yellow-800 p-6 rounded-2xl text-center">
                <p class="font-bold mb-1">No hay locales disponibles</p>
                <p class="text-sm">En este momento no se pueden realizar reservas porque no hay locales activos.</p>
            </div>
        {% endfor %}
    </div>

    <div class="mt-8 text-center">
        <a href="{{ path('app_servicios') }}" class="text-gray-400 hover:text-gray-600 font-semibold transition-colors">&larr; Volver a servicios</a>
    </div>
</div>
{% endblock %}

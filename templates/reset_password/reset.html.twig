{% extends 'base.html.twig' %}

{% block title %}Nueva Contraseña | Venus{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[70vh]">
    <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl w-full max-w-md border border-gray-100">
        
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Nueva Contraseña</h1>
            <p class="text-gray-500">Elige una contraseña segura</p>
        </div>

        {{ form_start(resetForm, {'attr': {'class': 'space-y-5'}}) }}
            
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Contraseña Nueva</label>
                {{ form_widget(resetForm.plainPassword.first, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': '••••••••'}}) }}
                <div class="text-red-500 text-sm font-bold mt-1">
                    {{ form_errors(resetForm.plainPassword.first) }}
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Repite la Contraseña</label>
                {{ form_widget(resetForm.plainPassword.second, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': '••••••••'}}) }}
                <div class="text-red-500 text-sm font-bold mt-1">
                    {{ form_errors(resetForm.plainPassword.second) }}
                </div>
            </div>

            <button type="submit" class="w-full bg-pink-600 hover:bg-pink-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5 mt-6">
                Cambiar contraseña
            </button>
            
        {{ form_end(resetForm) }}

    </div>
</div>
{% endblock %}

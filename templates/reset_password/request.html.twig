{% extends 'base.html.twig' %}

{% block title %}Recuperar Contraseña | Venus{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[70vh]">
    <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl w-full max-w-md border border-gray-100">
        
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Recuperar Contraseña</h1>
            <p class="text-gray-500">Introduce tu email para recibir un enlace</p>
        </div>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded mb-6" role="alert">
                <p class="text-sm font-medium">{{ flash_error }}</p>
            </div>
        {% endfor %}

        {{ form_start(requestForm, {'attr': {'class': 'space-y-5'}}) }}
            
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Correo Electrónico</label>
                {{ form_widget(requestForm.email, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': 'ejemplo@correo.com'}}) }}
                <div class="text-red-500 text-sm font-bold mt-1">
                    {{ form_errors(requestForm.email) }}
                </div>
            </div>

            <button type="submit" class="w-full bg-pink-600 hover:bg-pink-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5 mt-6">
                Enviar enlace
            </button>
            
        {{ form_end(requestForm) }}

        <div class="mt-8 text-center text-sm text-gray-500">
            ¿Te has acordado?
            <a href="{{ path('app_login') }}" class="text-gray-900 hover:text-pink-500 font-bold transition">Inicia sesión</a>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Nuestros Productos | Venus{% endblock %}

{% block body %}
<div class="text-center mb-12">
    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight mb-4">Productos Exclusivos</h1>
    <p class="text-lg text-gray-500 max-w-2xl mx-auto">Cuida tu cabello y tu piel en casa con los mismos productos profesionales que usamos en el salón.</p>
</div>

{% if productos is empty %}
    <div class="bg-white rounded-3xl p-10 text-center shadow-sm border border-gray-100 max-w-2xl mx-auto">
        <div class="w-16 h-16 bg-pink-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Tienda en preparación</h2>
        <p class="text-gray-500">Estamos llenando las estanterías con los mejores productos. Vuelve pronto.</p>
    </div>
{% else %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for producto in productos %}
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-shadow duration-300 flex flex-col h-full group">
                
                <div class="h-64 bg-white flex items-center justify-center relative overflow-hidden p-6">
                    {% if producto.imagen %}
                        <img src="{{ asset('uploads/productos/' ~ producto.imagen) }}" alt="{{ producto.nombre }}" class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500">
                    {% else %}
                        <div class="w-20 h-20 bg-pink-100 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                            <svg class="w-10 h-10 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                            </svg>
                        </div>
                    {% endif %}
                    
                    <div class="absolute top-4 right-4 bg-pink-100 text-pink-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-sm z-10">
                        {{ producto.marca }}
                    </div>
                </div>
                
                <div class="p-8 flex-grow flex flex-col">
                    <h3 class="text-2xl font-bold text-gray-900 mb-2">{{ producto.nombre }}</h3>
                    <p class="text-gray-500 mb-6 flex-grow text-sm line-clamp-3">{{ producto.descripcion|default('Añade este producto a tu próxima cita y llévatelo a casa tras tu tratamiento en el salón.') }}</p>
                    
                    <div class="flex flex-col sm:flex-row items-center justify-between mt-auto pt-6 border-t border-gray-50 gap-4">
                        <div class="w-full sm:w-auto text-center sm:text-left">
                            <p class="text-3xl font-extrabold text-gray-900">{{ producto.precio|number_format(2, ',', '.') }}€</p>
                        </div>
                        
                        {% if app.user %}
                            <a href="{{ path('app_producto_add_cita', {'id': producto.id}) }}" class="w-full sm:w-auto text-center bg-gray-900 hover:bg-pink-600 text-white font-bold py-2.5 px-5 rounded-xl transition-colors shadow-md">
                                Añadir a mi cita
                            </a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="w-full sm:w-auto text-center bg-pink-50 text-pink-700 hover:bg-pink-100 font-bold py-2.5 px-5 rounded-xl transition-colors text-sm border border-pink-100">
                                Comprar
                            </a>
                        {% endif %}
                    </div>
                </div>
                
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
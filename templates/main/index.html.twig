{% extends 'base.html.twig' %}

{% block title %}Peluquería Venus | Inicio
{% endblock %}

{% block body %}

	{# ===================== HERO ===================== #}
	<section
		class="relative bg-white rounded-2xl md:rounded-3xl shadow-xl overflow-hidden mb-10 md:mb-16">

		{# Fondo decorativo #}
		<div class="absolute inset-0 pointer-events-none overflow-hidden">
			<div class="absolute -top-24 -right-24 w-96 h-96 bg-pink-100 rounded-full opacity-60 blur-3xl"></div>
			<div class="absolute -bottom-16 -left-16 w-72 h-72 bg-pink-50 rounded-full opacity-80 blur-2xl"></div>
		</div>

		<div
			class="relative flex flex-col md:flex-row items-center md:min-h-[520px]">

			{# Texto #}
			<div class="px-6 py-8 md:p-16 md:w-1/2 flex flex-col justify-center z-10 order-2 md:order-1">

				<span class="inline-flex items-center gap-2 bg-pink-50 text-pink-600 font-bold tracking-wider uppercase text-xs px-3 py-1.5 rounded-full w-fit mb-4 md:mb-6 border border-pink-100">
					<span class="w-2 h-2 bg-pink-500 rounded-full animate-pulse"></span>
					Reservas abiertas
				</span>

				<h1 class="text-3xl md:text-6xl font-extrabold text-gray-900 leading-tight mb-4 md:mb-6">
					Tu mejor versión,<br>
					<span class="text-pink-500 relative">
						a un clic
						<svg class="absolute -bottom-2 left-0 w-full" viewbox="0 0 200 12" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M2 8 Q50 2, 100 6 Q150 10, 198 4" stroke="#f9a8d4" stroke-width="3" stroke-linecap="round" fill="none"/>
						</svg>
					</span>
					de distancia.
				</h1>

				<p class="text-base md:text-lg text-gray-500 mb-6 md:mb-8 leading-relaxed">
					Reserva tu cita en segundos, descubre nuestros tratamientos premium y déjate mimar por los mejores profesionales.
				</p>

				<div class="flex flex-wrap gap-3 md:gap-4 mb-6 md:mb-10">
					<a href="{{ path('app_servicios') }}" class="flex-1 min-w-[140px] text-center bg-pink-600 hover:bg-pink-500 text-white font-bold py-3 md:py-3.5 px-6 md:px-8 rounded-full shadow-lg hover:shadow-pink-500/30 transition-all duration-300 transform hover:-translate-y-0.5">
						Reservar Cita
					</a>
					<a href="{{ path('app_servicios') }}" class="flex-1 min-w-[140px] text-center bg-white border-2 border-gray-200 hover:border-pink-300 text-gray-700 font-bold py-3 md:py-3.5 px-6 md:px-8 rounded-full transition-all duration-300 hover:text-pink-600">
						Ver Servicios
					</a>
				</div>

				{# Stats #}
				<div class="flex flex-wrap gap-4 md:gap-8 pt-5 md:pt-6 border-t border-gray-100">
					<div class="flex-1 min-w-[70px]">
						<p class="text-xl md:text-2xl font-extrabold text-gray-900">500+</p>
						<p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Clientes felices</p>
					</div>
					<div class="hidden md:block w-px bg-gray-100"></div>
					<div class="flex-1 min-w-[70px]">
						<p class="text-xl md:text-2xl font-extrabold text-gray-900">10+</p>
						<p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Años de experiencia</p>
					</div>
					<div class="hidden md:block w-px bg-gray-100"></div>
					<div class="flex-1 min-w-[70px]">
						<p class="text-xl md:text-2xl font-extrabold text-gray-900">4.9★</p>
						<p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Valoración media</p>
					</div>
				</div>
			</div>

			{# Imagen #}
			<div class="w-full md:w-1/2 h-56 sm:h-72 md:h-auto md:self-stretch relative order-1 md:order-2">
				<img
				src="https://images.unsplash.com/photo-1560066984-138dadb4c035?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Peluquería Venus" class="w-full h-full object-cover md:absolute md:inset-0">
				{# Badge flotante #}
				<div class="absolute bottom-4 left-4 md:bottom-6 md:left-6 bg-white rounded-xl md:rounded-2xl shadow-xl px-3 md:px-5 py-2 md:py-3 flex items-center gap-2 md:gap-3">
					<div class="w-8 h-8 md:w-10 md:h-10 bg-pink-100 rounded-lg md:rounded-xl flex items-center justify-center flex-shrink-0">
						<svg class="w-4 h-4 md:w-5 md:h-5 text-pink-600" fill="none" stroke="currentColor" viewbox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
						</svg>
					</div>
					<div>
						<p class="text-xs text-gray-400 font-medium">Próxima disponibilidad</p>
						<p class="text-xs md:text-sm font-bold text-gray-900">¡HOY MISMO!</p>
					</div>
				</div>
			</div>

		</div>
	</section>

	{# ===================== CÓMO FUNCIONA ===================== #}
	<section class="mb-16">
		<div class="text-center mb-10">
			<span class="text-pink-500 font-bold tracking-wider uppercase text-sm">Así de fácil</span>
			<h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mt-2">¿Cómo funciona?</h2>
		</div>

		<div
			class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
			{# Línea conectora solo en desktop #}
			<div class="hidden md:block absolute top-10 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-pink-200 via-pink-300 to-pink-200 z-0"></div>

			<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center relative z-10 hover:shadow-md transition-shadow">
				<div class="w-16 h-16 bg-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-pink-500/20">
					<span class="text-2xl font-extrabold text-white">1</span>
				</div>
				<h3 class="text-lg font-bold text-gray-900 mb-2">Elige tu servicio</h3>
				<p class="text-gray-500 text-sm leading-relaxed">Explora nuestro catálogo de tratamientos y elige el que mejor se adapta a ti.</p>
			</div>

			<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center relative z-10 hover:shadow-md transition-shadow">
				<div class="w-16 h-16 bg-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-pink-400/20">
					<span class="text-2xl font-extrabold text-white">2</span>
				</div>
				<h3 class="text-lg font-bold text-gray-900 mb-2">Selecciona fecha y hora</h3>
				<p class="text-gray-500 text-sm leading-relaxed">Consulta nuestra agenda en tiempo real y reserva el hueco que más te convenga.</p>
			</div>

			<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center relative z-10 hover:shadow-md transition-shadow">
				<div class="w-16 h-16 bg-pink-400 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-pink-300/20">
					<span class="text-2xl font-extrabold text-white">3</span>
				</div>
				<h3 class="text-lg font-bold text-gray-900 mb-2">¡Listo, nos vemos!</h3>
				<p class="text-gray-500 text-sm leading-relaxed">Recibirás una confirmación y te esperaremos con todo preparado para ti.</p>
			</div>
		</div>
	</section>

	{# ===================== SERVICIOS DESTACADOS ===================== #}
	<section class="mb-16">
		<div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
			<div>
				<span class="text-pink-500 font-bold tracking-wider uppercase text-sm">Lo más solicitado</span>
				<h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mt-2">Servicios destacados</h2>
			</div>
			<a href="{{ path('app_servicios') }}" class="text-pink-600 font-bold hover:text-pink-500 transition-colors flex items-center gap-1 text-sm flex-shrink-0">
				Ver todos los servicios
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
				</svg>
			</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

			{% for servicio in servicios_destacados %}
				{% set imagen = 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&w=600&q=80' %}
				{% set desc = 'Corte personalizado adaptado a tu tipo de rostro y estilo de vida.' %}
				
				{% if loop.index == 2 %}
					{% set imagen = 'https://images.unsplash.com/photo-1562322140-8baeececf3df?auto=format&fit=crop&w=600&q=80' %}
					{% set desc = 'Balayage, mechas, tinte uniforme… Tu color soñado con productos premium.' %}
				{% elseif loop.index == 3 %}
					{% set imagen = 'https://images.unsplash.com/photo-1519735777090-ec97162dc266?auto=format&fit=crop&w=600&q=80' %}
					{% set desc = 'Hidratación profunda, keratina y más. Dale a tu cabello el mimo que merece.' %}
				{% endif %}

				<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden group hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
					<div class="h-48 overflow-hidden">
						<img src="{{ imagen }}" alt="{{ servicio.nombre }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
					</div>
					<div class="p-6">
						<div class="flex justify-between items-start mb-3">
							<h3 class="text-lg font-bold text-gray-900">{{ servicio.nombre }}</h3>
							<span class="text-pink-600 font-extrabold text-lg">{{ servicio.precio|number_format(2, ',', '.') }}€</span>
						</div>
						<p class="text-gray-500 text-sm mb-5">{{ desc }}</p>
						<a href="{{ path('app_reservar', {'id': servicio.id}) }}" class="block w-full text-center bg-gray-50 hover:bg-pink-600 text-gray-700 hover:text-white font-bold py-2.5 rounded-xl transition-all duration-300 text-sm border border-gray-100 hover:border-transparent">
							Reservar
						</a>
					</div>
				</div>
			{% else %}
				<p class="text-gray-500 col-span-3 text-center py-6">No hay servicios destacados disponibles en este momento.</p>
			{% endfor %}

		</div>
	</section>

	{# ===================== POR QUÉ ELEGIRNOS ===================== #}
	<section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">

		<div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md hover:border-pink-100 transition-all duration-300 group">
			<div class="w-12 h-12 bg-pink-100 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-pink-600 transition-colors duration-300">
				<svg class="w-6 h-6 text-pink-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"/>
				</svg>
			</div>
			<h3 class="text-xl font-bold text-gray-900 mb-2">Estilo Único</h3>
			<p class="text-gray-500 text-sm leading-relaxed">Nuestros estilistas están al día con las últimas tendencias para sacar tu mejor versión.</p>
		</div>

		<div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md hover:border-pink-100 transition-all duration-300 group">
			<div class="w-12 h-12 bg-pink-100 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-pink-600 transition-colors duration-300">
				<svg class="w-6 h-6 text-pink-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
				</svg>
			</div>
			<h3 class="text-xl font-bold text-gray-900 mb-2">Productos Premium</h3>
			<p class="text-gray-500 text-sm leading-relaxed">Solo trabajamos con marcas top del mercado para cuidar la salud de tu cabello.</p>
		</div>

		<div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md hover:border-pink-100 transition-all duration-300 group">
			<div class="w-12 h-12 bg-pink-100 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-pink-600 transition-colors duration-300">
				<svg class="w-6 h-6 text-pink-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewbox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
				</svg>
			</div>
			<h3 class="text-xl font-bold text-gray-900 mb-2">Reserva 24/7</h3>
			<p class="text-gray-500 text-sm leading-relaxed">Olvídate de llamar por teléfono. Mira nuestra agenda y elige tu hueco desde el móvil.</p>
		</div>

	</section>

	{# ===================== TESTIMONIOS ===================== #}
	<section class="mb-16">
		<div class="text-center mb-10">
			<span class="text-pink-500 font-bold tracking-wider uppercase text-sm">Opiniones reales</span>
			<h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mt-2">Lo que dicen nuestros clientes</h2>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

			{% if resenas %}
				{% for cita in resenas %}
					{% if loop.index == 2 %}
						{% set bgColor = 'bg-purple-200' %}
						{% set textColor = 'text-purple-700' %}
					{% elseif loop.index == 3 %}
						{% set bgColor = 'bg-green-200' %}
						{% set textColor = 'text-green-700' %}
					{% else %}
						{% set bgColor = 'bg-pink-200' %}
						{% set textColor = 'text-pink-700' %}
					{% endif %}

					<div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
						<div class="flex gap-1 mb-4">
							{% for i in 1..5 %}
								<svg class="w-4 h-4 {{ i <= cita.valoracion ? 'text-yellow-400' : 'text-gray-200' }} fill-current" viewbox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
							{% endfor %}
						</div>
						<p class="text-gray-600 text-sm leading-relaxed mb-5 italic">"{{ cita.comentarioValoracion }}"</p>
						<div class="flex items-center gap-3">
							<div class="w-10 h-10 rounded-full {{ bgColor }} flex items-center justify-center flex-shrink-0">
								<span class="{{ textColor }} font-bold text-sm">{{ cita.usuario.nombre|slice(0, 2)|upper }}</span>
							</div>
							<div>
								<p class="font-bold text-gray-900 text-sm">{{ cita.usuario.nombre }}</p>
								<p class="text-gray-400 text-xs">{{ cita.fechaInicio|date('d/m/Y') }}</p>
							</div>
						</div>
					</div>
				{% endfor %}
			{% else %}
				<div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
					<div class="flex gap-1 mb-4">
						{% for i in 1..5 %}<svg class="w-4 h-4 text-yellow-400 fill-current" viewbox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>{% endfor %}
					</div>
					<p class="text-gray-600 text-sm leading-relaxed mb-5 italic">"Reservé por la web en menos de un minuto. Llegué, me atendieron genial y salí con un corte espectacular. Totalmente recomendado."</p>
					<div class="flex items-center gap-3">
						<div class="w-10 h-10 rounded-full bg-pink-200 flex items-center justify-center flex-shrink-0">
							<span class="text-pink-700 font-bold text-sm">ML</span>
						</div>
						<div>
							<p class="font-bold text-gray-900 text-sm">María López</p>
							<p class="text-gray-400 text-xs">Cliente habitual</p>
						</div>
					</div>
				</div>

				<div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
					<div class="flex gap-1 mb-4">
						{% for i in 1..5 %}<svg class="w-4 h-4 text-yellow-400 fill-current" viewbox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>{% endfor %}
					</div>
					<p class="text-gray-600 text-sm leading-relaxed mb-5 italic">"El balayage me quedó precioso. Los productos que usan son de altísima calidad y el resultado dura muchísimo. ¡Volvería mil veces!"</p>
					<div class="flex items-center gap-3">
						<div class="w-10 h-10 rounded-full bg-purple-200 flex items-center justify-center flex-shrink-0">
							<span class="text-purple-700 font-bold text-sm">SR</span>
						</div>
						<div>
							<p class="font-bold text-gray-900 text-sm">Sofía Ramírez</p>
							<p class="text-gray-400 text-xs">Nueva clienta</p>
						</div>
					</div>
				</div>

				<div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
					<div class="flex gap-1 mb-4">
						{% for i in 1..5 %}<svg class="w-4 h-4 text-yellow-400 fill-current" viewbox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>{% endfor %}
					</div>
					<p class="text-gray-600 text-sm leading-relaxed mb-5 italic">"Genial poder ver la disponibilidad en tiempo real y no tener que llamar. La atención es 10/10 y el ambiente del salón es muy acogedor."</p>
					<div class="flex items-center gap-3">
						<div class="w-10 h-10 rounded-full bg-green-200 flex items-center justify-center flex-shrink-0">
							<span class="text-green-700 font-bold text-sm">AG</span>
						</div>
						<div>
							<p class="font-bold text-gray-900 text-sm">Ana García</p>
							<p class="text-gray-400 text-xs">Cliente VIP</p>
						</div>
					</div>
				</div>
			{% endif %}

		</div>
	</section>

	{# ===================== CTA FINAL ===================== #}
	<section class="bg-gray-900 rounded-3xl overflow-hidden relative mb-4">
		<div class="absolute inset-0 pointer-events-none overflow-hidden">
			<div class="absolute -top-20 -right-20 w-72 h-72 bg-pink-600 rounded-full opacity-10 blur-3xl"></div>
			<div class="absolute -bottom-20 -left-20 w-72 h-72 bg-pink-400 rounded-full opacity-10 blur-3xl"></div>
		</div>
		<div class="relative px-10 py-16 text-center">
			<span class="text-pink-400 font-bold tracking-wider uppercase text-sm">¿Listo para el cambio?</span>
			<h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">
				Tu cita perfecta te está esperando
			</h2>
			<p class="text-gray-400 mb-8 max-w-xl mx-auto">
				Únete a cientos de clientes que ya reservan online. Rápido, sencillo y sin esperas.
			</p>
			<div class="flex flex-wrap justify-center gap-4">
				<a href="{{ path('app_register') }}" class="bg-pink-600 hover:bg-pink-500 text-white font-bold py-3.5 px-10 rounded-full shadow-lg hover:shadow-pink-500/30 transition-all duration-300 transform hover:-translate-y-0.5">
					Crear cuenta gratis
				</a>
				<a href="{{ path('app_contacto') }}" class="bg-white/10 hover:bg-white/20 border border-white/20 text-white font-bold py-3.5 px-10 rounded-full transition-all duration-300">
					Contactar
				</a>
			</div>
		</div>
	</section>

{% endblock %}

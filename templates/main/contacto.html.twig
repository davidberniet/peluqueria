{% extends 'base.html.twig' %}

{% block title %}Contacto | Venus{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto py-6">

    {# ===== HERO ===== #}
    <div class="bg-white rounded-3xl shadow-xl overflow-hidden mb-12">
        <div class="flex flex-col md:flex-row items-stretch">
            <div class="p-6 sm:p-10 md:p-16 md:w-1/2 flex flex-col justify-center">
                <span class="text-pink-500 font-bold tracking-wider uppercase text-sm mb-3">Sobre nosotros</span>
                <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-5">
                    Más que una<br><span class="text-pink-500">peluquería</span>
                </h1>
                <p class="text-gray-500 text-lg leading-relaxed mb-6">
                    En Venus llevamos años cuidando el cabello de nuestros clientes con mimo,
                    pasión y los mejores productos del mercado. Somos un equipo de estilistas
                    apasionados por su trabajo y comprometidos con tu satisfacción.
                </p>
                <a href="{{ path('app_servicios') }}"
                   class="inline-block self-start bg-pink-600 hover:bg-pink-500 text-white font-bold py-3 px-8 rounded-full shadow-lg hover:shadow-pink-500/30 transition duration-300">
                    Ver nuestros servicios
                </a>
            </div>
            <div class="md:w-1/2 min-h-[220px] md:min-h-[300px] bg-cover bg-center"
                 style="background-image: url('https://images.unsplash.com/photo-1521590832167-7bcbfaa6381f?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80');">
            </div>
        </div>
    </div>

    {# ===== VALORES ===== #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition text-center">
            <div class="w-12 h-12 bg-pink-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
            </div>
            <h3 class="text-lg font-extrabold text-gray-900 mb-2">Calidad Premium</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Usamos exclusivamente productos de alta gama para garantizar resultados excepcionales y duraderos.</p>
        </div>
        <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition text-center">
            <div class="w-12 h-12 bg-pink-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                </svg>
            </div>
            <h3 class="text-lg font-extrabold text-gray-900 mb-2">Creatividad & Estilo</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Nuestros estilistas se forman continuamente en las últimas tendencias para ofrecerte siempre lo mejor.</p>
        </div>
        <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition text-center">
            <div class="w-12 h-12 bg-pink-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
            </div>
            <h3 class="text-lg font-extrabold text-gray-900 mb-2">Trato Personalizado</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Cada cliente es único. Escuchamos tus necesidades y adaptamos cada servicio a ti.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">

        {# ===== INFORMACIÓN DE CONTACTO ===== #}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="flex items-center gap-3 p-6 border-b border-gray-100 bg-gray-50">
                <div class="w-9 h-9 bg-pink-100 rounded-xl flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-xl font-extrabold text-gray-900">Dónde estamos</h2>
                    <p class="text-gray-400 text-sm">Ven a vernos cuando quieras</p>
                </div>
            </div>
            <div class="p-5 sm:p-6 space-y-5">

                {% if local %}
                    <div class="flex items-start gap-4">
                        <div class="bg-pink-100 p-3 rounded-xl shrink-0">
                            <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Dirección</p>
                            <p class="font-bold text-gray-900">{{ local.direccion }}</p>
                            <p class="text-gray-500 text-sm">{{ local.ciudad }}</p>
                        </div>
                    </div>

                    {% if local.telefono %}
                    <div class="flex items-start gap-4">
                        <div class="bg-green-100 p-3 rounded-xl shrink-0">
                            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Teléfono</p>
                            <a href="tel:{{ local.telefono }}" class="font-bold text-gray-900 hover:text-pink-600 transition-colors">
                                {{ local.telefono }}
                            </a>
                        </div>
                    </div>
                    {% endif %}

                    {% if local.email %}
                    <div class="flex items-start gap-4">
                        <div class="bg-blue-100 p-3 rounded-xl shrink-0">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Email</p>
                            <a href="mailto:{{ local.email }}" class="font-bold text-gray-900 hover:text-pink-600 transition-colors">
                                {{ local.email }}
                            </a>
                        </div>
                    </div>
                    {% endif %}

                {% else %}
                    <p class="text-gray-400 text-center py-6">Información de contacto no disponible.</p>
                {% endif %}

                <div class="pt-4 border-t border-gray-100">
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Síguenos</p>
                    <div class="flex gap-3">
                        <a href="#" class="bg-gray-100 hover:bg-pink-100 hover:text-pink-600 p-3 rounded-xl transition-colors text-gray-600 font-bold text-sm">
                            Instagram
                        </a>
                        <a href="#" class="bg-gray-100 hover:bg-blue-100 hover:text-blue-600 p-3 rounded-xl transition-colors text-gray-600 font-bold text-sm">
                            Facebook
                        </a>
                    </div>
                </div>
            </div>
        </div>

        {# ===== FORMULARIO DE CONTACTO ===== #}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="flex items-center gap-3 p-6 border-b border-gray-100 bg-gray-50">
                <div class="w-9 h-9 bg-pink-100 rounded-xl flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-xl font-extrabold text-gray-900">Escríbenos</h2>
                    <p class="text-gray-400 text-sm">Te respondemos en menos de 24 horas</p>
                </div>
            </div>
            <div class="p-5 sm:p-6">
                <form id="form-contacto" class="flex flex-col gap-4" onsubmit="return enviarContacto(event)" data-url="{{ path('app_contacto_enviar') }}">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-gray-600 mb-2">Tu nombre</label>
                            <input id="contacto-nombre" type="text" placeholder="María García"
                                   class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400 transition-colors"
                                   required>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-600 mb-2">Email</label>
                            <input id="contacto-email" type="email" placeholder="tu@email.com"
                                   class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400 transition-colors"
                                   required>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-600 mb-2">Asunto</label>
                        <input id="contacto-asunto" type="text" placeholder="¿En qué podemos ayudarte?"
                               class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400 transition-colors"
                               required>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-600 mb-2">Mensaje</label>
                        <textarea id="contacto-mensaje" rows="4" placeholder="Escribe aquí tu mensaje..."
                                  class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400 transition-colors resize-none"
                                  required></textarea>
                    </div>
                    
                    <div class="flex items-start mt-2 mb-2">
                        <div class="flex items-center h-5">
                            <input id="contacto-gdpr" type="checkbox" required class="w-5 h-5 text-pink-600 bg-gray-100 border-gray-300 rounded focus:ring-pink-500">
                        </div>
                        <label for="contacto-gdpr" class="ml-2 text-sm font-medium text-gray-600">
                            He leído y acepto la <a href="#" class="text-pink-600 hover:underline">Política de Privacidad</a> y consiento el tratamiento de mis datos para esta consulta.
                        </label>
                    </div>

                    <button type="submit"
                            class="w-full bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3.5 rounded-xl shadow-sm transition-colors text-base">
                        Enviar mensaje
                    </button>
                    <div id="contacto-ok" class="hidden bg-green-50 border border-green-200 text-green-700 font-semibold px-4 py-3 rounded-xl text-sm text-center">
                        Mensaje enviado correctamente. Te responderemos pronto.
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# ===== MAPA ===== #}
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="flex items-center gap-3 p-6 border-b border-gray-100 bg-gray-50">
            <div class="w-9 h-9 bg-pink-100 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                </svg>
            </div>
            <div>
                <h2 class="text-xl font-extrabold text-gray-900">Cómo llegar</h2>
                <p class="text-gray-400 text-sm">Visítanos en Calle Ecuador, 21 — Alcalá la Real, Jaén</p>
            </div>
        </div>
        <div class="h-64 sm:h-80 w-full">
            <iframe
                width="100%"
                height="100%"
                style="border:0;"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3167.1641060791003!2d-3.928131423866562!3d37.456847072067134!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd6def6d5c2e79f5%3A0x957b142e58ab44d2!2sC.%20Ecuador%2C%2021%2C%2023680%20Alcal%C3%A1%20la%20Real%2C%20Ja%C3%A9n!5e0!3m2!1ses!2ses!4v1779100820343!5m2!1ses!2ses">
            </iframe>
        </div>
    </div>

</div>

<script>
async function enviarContacto(e) {
    e.preventDefault();
    const form = document.getElementById('form-contacto');
    form.classList.add('opacity-50', 'pointer-events-none');

    const body = new URLSearchParams({
        nombre:  document.getElementById('contacto-nombre').value,
        email:   document.getElementById('contacto-email').value,
        asunto:  document.getElementById('contacto-asunto').value,
        mensaje: document.getElementById('contacto-mensaje').value,
    });

    try {
        const res = await fetch(form.dataset.url, { method: 'POST', body });
        const data = await res.json();
        if (data.ok) {
            form.reset();
            document.getElementById('contacto-ok').classList.remove('hidden');
            setTimeout(() => document.getElementById('contacto-ok').classList.add('hidden'), 5000);
        } else {
            alert(data.error || 'Error al enviar el mensaje. Inténtalo de nuevo.');
        }
    } catch {
        alert('Error de conexión. Inténtalo de nuevo.');
    } finally {
        form.classList.remove('opacity-50', 'pointer-events-none');
    }
    return false;
}
</script>
{% endblock %}

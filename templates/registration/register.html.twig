{% extends 'base.html.twig' %}

{% block title %}Crear Cuenta | Venus{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[70vh]">
    <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl w-full max-w-md border border-gray-100">
        
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Únete a Venus</h1>
            <p class="text-gray-500">Crea tu cuenta en segundos</p>
        </div>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}
            
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Tu Nombre</label>
                {{ form_widget(registrationForm.nombre, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': 'Ej. María'}}) }}
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Correo Electrónico</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': 'ejemplo@correo.com'}}) }}
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Contraseña</label>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': '••••••••'}}) }}
            </div>

            <div class="flex items-center mt-4">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-5 h-5 text-pink-600 bg-gray-100 border-gray-300 rounded focus:ring-pink-500'}}) }}
                <label class="ml-2 text-sm font-medium text-gray-600">Acepto los términos y condiciones</label>
            </div>

            <button type="submit" class="w-full bg-pink-600 hover:bg-pink-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5 mt-6">
                Crear Cuenta
            </button>
            
        {{ form_end(registrationForm) }}

        <div class="mt-8 text-center text-sm text-gray-500">
            ¿Ya tienes cuenta? <a href="{{ path('app_login') }}" class="text-gray-900 hover:text-pink-500 font-bold transition">Inicia sesión</a>
        </div>
    </div>
</div>
{% endblock %}
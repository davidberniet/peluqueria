{% extends 'base.html.twig' %}

{% block title %}Crear Cuenta | Venus{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[70vh]">
    <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl w-full max-w-md border border-gray-100">

        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Únete a Venus</h1>
            <p class="text-gray-500">Crea tu cuenta en segundos</p>
        </div>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Tu Nombre</label>
            {{ form_widget(registrationForm.nombre, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': 'Ej. María'}}) }}
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Correo Electrónico</label>
            {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': 'ejemplo@correo.com'}}) }}
        </div>
        <div class="text-red-500 text-sm font-bold mt-1">
            {{ form_errors(registrationForm.email) }}
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Teléfono</label>
            {{ form_widget(registrationForm.telefono, {'attr': {'class': 'w-full border border-gray-200 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-pink-400'}}) }}
        </div>
        <div class="text-red-500 text-sm font-bold mt-1">
            {{ form_errors(registrationForm.telefono) }}
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Contraseña</label>
            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition bg-gray-50 focus:bg-white', 'placeholder': '••••••••', 'id': 'registration_password'}}) }}

            <div class="mt-3">
                <div class="flex justify-between items-center mb-1">
                    <span class="text-xs font-semibold text-gray-500">Seguridad de la contraseña</span>
                    <span id="password-strength-text" class="text-xs font-bold text-gray-400">Ninguna</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-1.5 flex overflow-hidden">
                    <div id="strength-bar-1" class="h-1.5 w-1/4 bg-gray-200 transition-colors duration-300"></div>
                    <div id="strength-bar-2" class="h-1.5 w-1/4 bg-gray-200 transition-colors duration-300 border-l border-white"></div>
                    <div id="strength-bar-3" class="h-1.5 w-1/4 bg-gray-200 transition-colors duration-300 border-l border-white"></div>
                    <div id="strength-bar-4" class="h-1.5 w-1/4 bg-gray-200 transition-colors duration-300 border-l border-white"></div>
                </div>
                <ul class="text-[11px] text-gray-500 mt-2 space-y-1" id="password-criteria">
                    <li id="criterion-length" class="flex items-center"><span class="mr-1">—</span> Mínimo 8 caracteres</li>
                    <li id="criterion-upper" class="flex items-center"><span class="mr-1">—</span> Una letra mayúscula</li>
                    <li id="criterion-lower" class="flex items-center"><span class="mr-1">—</span> Una letra minúscula</li>
                    <li id="criterion-number" class="flex items-center"><span class="mr-1">—</span> Un número</li>
                </ul>
            </div>
        </div>

        <div class="flex items-center mt-4">
            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-5 h-5 text-pink-600 bg-gray-100 border-gray-300 rounded focus:ring-pink-500'}}) }}
            <label class="ml-2 text-sm font-medium text-gray-600">Acepto los términos y la Política de Privacidad</label>
        </div>

        <button type="submit" class="w-full bg-pink-600 hover:bg-pink-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5 mt-6">
            Crear Cuenta
        </button>

        {{ form_end(registrationForm) }}

        <div class="mt-8 text-center text-sm text-gray-500">
            ¿Ya tienes cuenta?
            <a href="{{ path('app_login') }}" class="text-gray-900 hover:text-pink-500 font-bold transition">Inicia sesión</a>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const passwordInput = document.getElementById('registration_password') || document.getElementById('registration_form_plainPassword');

        if (!passwordInput) return;

        const strengthText = document.getElementById('password-strength-text');
        const bars = [
            document.getElementById('strength-bar-1'),
            document.getElementById('strength-bar-2'),
            document.getElementById('strength-bar-3'),
            document.getElementById('strength-bar-4')
        ];

        const criteria = {
            length: { el: document.getElementById('criterion-length'), regex: /.{8,}/ },
            upper:  { el: document.getElementById('criterion-upper'),  regex: /[A-Z]/ },
            lower:  { el: document.getElementById('criterion-lower'),  regex: /[a-z]/ },
            number: { el: document.getElementById('criterion-number'), regex: /[0-9]/ }
        };

        passwordInput.addEventListener('input', function () {
            const val = this.value;
            let score = 0;

            for (const [key, req] of Object.entries(criteria)) {
                const ok = req.regex.test(val);
                req.el.classList.toggle('text-green-500', ok);
                req.el.classList.toggle('text-gray-500', !ok);
                req.el.querySelector('span').innerText = ok ? '+' : '—';
                if (ok) score++;
            }

            bars.forEach(b => {
                b.className = 'h-1.5 w-1/4 bg-gray-200 transition-colors duration-300 border-l border-white';
            });

            if (val.length === 0) {
                strengthText.innerText = 'Ninguna';
                strengthText.className = 'text-xs font-bold text-gray-400';
            } else if (score === 1) {
                strengthText.innerText = 'Débil';
                strengthText.className = 'text-xs font-bold text-red-500';
                bars[0].classList.replace('bg-gray-200', 'bg-red-500');
            } else if (score === 2) {
                strengthText.innerText = 'Regular';
                strengthText.className = 'text-xs font-bold text-orange-500';
                bars[0].classList.replace('bg-gray-200', 'bg-orange-500');
                bars[1].classList.replace('bg-gray-200', 'bg-orange-500');
            } else if (score === 3) {
                strengthText.innerText = 'Buena';
                strengthText.className = 'text-xs font-bold text-yellow-400';
                bars[0].classList.replace('bg-gray-200', 'bg-yellow-400');
                bars[1].classList.replace('bg-gray-200', 'bg-yellow-400');
                bars[2].classList.replace('bg-gray-200', 'bg-yellow-400');
            } else if (score === 4) {
                strengthText.innerText = 'Fuerte';
                strengthText.className = 'text-xs font-bold text-green-500';
                bars.forEach(b => b.classList.replace('bg-gray-200', 'bg-green-500'));
            }
        });
    });
</script>
{% endblock %}

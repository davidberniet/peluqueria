<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}Venus{% endblock %}
		</title>
		<link rel="icon" type="image/jpeg" href="{{ asset('images/logoVenus.png') }}">
		<script src="https://unpkg.com/@tailwindcss/browser@4"></script>
	</head>

	<body class="bg-gray-300 text-gray-800 min-h-screen flex flex-col font-sans antialiased">

		{% block navbar %}
		<nav class="bg-white border-b border-pink-300 sticky top-0 z-50 shadow-sm">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between h-16 md:h-20 items-center">

					<div class="flex-shrink-0 flex items-center">
						<a href="{{ path('app_home') }}" class="transform hover:scale-105 transition-transform duration-200">
							<img src="{{ asset('images/logoVenus.png') }}" alt="Logo Venus" class="h-10 md:h-14 w-auto mix-blend-multiply">
						</a>
					</div>

					<div class="hidden md:flex space-x-1 items-center">
						<a href="{{ path('app_home') }}" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition">
							Inicio
						</a>
						<a href="{{ path('app_servicios') }}" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition">
							Servicios
						</a>
						<a href="{{ path('app_productos') }}" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition">
							Productos
						</a>
						<a href="{{ path('app_contacto') }}" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition">
							Contacto
						</a>

						<div class="h-5 w-px bg-gray-200 mx-3"></div>

						{% if app.user %}
							<span class="px-3 py-2 text-sm font-bold text-gray-900">
								Hola, <span class="text-pink-600">{{ app.user.nombre }}</span>
							</span>

							{% if is_granted('ROLE_ADMIN') %}
								<a href="{{ path('app_admin_dashboard') }}" class="px-3 py-2 rounded-lg text-sm font-bold text-pink-600 hover:bg-pink-50 transition">
									Panel Admin
								</a>
							{% else %}
								<a href="{{ path('app_cliente_perfil') }}" class="px-3 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50 transition">
									Mi Perfil
								</a>
								<a href="{{ path('app_cliente_citas') }}" class="px-3 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50 transition">
									Mis Citas
								</a>
							{% endif %}

							<a href="{{ path('app_logout') }}" onclick="return confirm('¿Estás seguro de que quieres cerrar sesión?')" class="px-4 py-2 rounded-lg text-sm font-bold text-white bg-red-500 hover:bg-red-600 shadow-md transition ml-2">
								Salir
							</a>

						{% else %}
							<a href="{{ path('app_login') }}" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition">
								Iniciar sesión
							</a>
							<a href="{{ path('app_register') }}" class="px-5 py-2.5 rounded-full text-sm font-bold bg-gray-900 text-white hover:bg-pink-500 shadow-md hover:shadow-lg transition-all ml-2 transform hover:-translate-y-0.5">
								Crear Cuenta
							</a>
						{% endif %}
					</div>

					<div class="md:hidden flex items-center">
						<button id="mobile-menu-btn" class="text-gray-600 hover:text-pink-600 focus:outline-none p-2 rounded-lg hover:bg-gray-50 transition-colors">
							<svg class="w-7 h-7" fill="none" stroke="currentColor" viewbox="0 0 24 24">
								<path id="icon-menu" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
								<path id="icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
							</svg>
						</button>
					</div>

				</div>
			</div>

			<div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg absolute w-full z-50">
				<div class="px-4 pt-4 pb-6 space-y-2">
					<a href="{{ path('app_home') }}" class="block px-4 py-3 rounded-xl text-base font-bold text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors">Inicio</a>
					<a href="{{ path('app_servicios') }}" class="block px-4 py-3 rounded-xl text-base font-bold text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors">Servicios</a>
					<a href="{{ path('app_productos') }}" class="block px-4 py-3 rounded-xl text-base font-bold text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors">Productos</a>
					<a href="{{ path('app_contacto') }}" class="block px-4 py-3 rounded-xl text-base font-bold text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors">Contacto</a>

					<div class="h-px bg-gray-100 my-4"></div>

					{% if app.user %}
						<div class="px-4 py-2 mb-2 bg-gray-50 rounded-xl">
							<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Conectado como</p>
							<p class="text-lg font-bold text-gray-900">{{ app.user.nombre }}</p>
						</div>

						<a href="{{ path('app_cliente_perfil') }}" class="block px-4 py-3 rounded-xl text-base font-bold text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors">Mi Perfil</a>
						<a href="{{ path('app_cliente_citas') }}" class="block px-4 py-3 rounded-xl text-base font-bold text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors">Mis Citas</a>

						{% if is_granted('ROLE_ADMIN') %}
							<a href="{{ path('app_admin_dashboard') }}" class="block px-4 py-3 rounded-xl text-base font-bold text-pink-600 bg-pink-50 border border-pink-100 mt-2">Panel Admin</a>
						{% endif %}

						<a href="{{ path('app_logout') }}" onclick="return confirm('¿Estás seguro de que quieres cerrar sesión?')" class="block w-full text-center mt-6 px-4 py-3.5 rounded-xl text-base font-bold text-white bg-red-500 hover:bg-red-600 shadow-md transition-colors">Salir</a>
					{% else %}
						<a href="{{ path('app_login') }}" class="block px-4 py-3 rounded-xl text-base font-bold text-gray-700 hover:bg-gray-50 transition-colors">Iniciar sesión</a>
						<a href="{{ path('app_register') }}" class="block w-full text-center mt-4 px-4 py-3.5 rounded-xl text-base font-bold bg-gray-900 text-white shadow-md hover:bg-pink-500 transition-colors">Crear Cuenta</a>
					{% endif %}
				</div>
			</div>
		</nav>
		{% endblock %}

		{# ===== SISTEMA GLOBAL DE NOTIFICACIONES (FLASH MESSAGES) ===== #}
		{% set all_flashes = {
			'success':        app.flashes('success'),
			'error':          app.flashes('error'),
			'success_perfil': app.flashes('success_perfil'),
			'error_perfil':   app.flashes('error_perfil'),
			'success_password': app.flashes('success_password'),
			'error_password': app.flashes('error_password')
		} %}

		{% set has_flashes = (
			all_flashes.success|length > 0 or
			all_flashes.error|length > 0 or
			all_flashes.success_perfil|length > 0 or
			all_flashes.error_perfil|length > 0 or
			all_flashes.success_password|length > 0 or
			all_flashes.error_password|length > 0
		) %}

		{% if has_flashes %}
		<div id="toast-container" class="fixed top-20 right-4 z-[9999] flex flex-col gap-3 max-w-sm w-full pointer-events-none">

			{% for msg in all_flashes.success %}
			<div class="toast-item pointer-events-auto flex items-start gap-3 bg-white border border-green-100 rounded-2xl shadow-xl px-4 py-3.5 opacity-0 translate-x-8 transition-all duration-500" data-type="success">
				<div class="w-9 h-9 rounded-xl bg-green-100 flex items-center justify-center shrink-0 mt-0.5">
					<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
					</svg>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-xs font-bold text-green-600 uppercase tracking-wider mb-0.5">¡Éxito!</p>
					<p class="text-sm font-medium text-gray-800 leading-snug">{{ msg }}</p>
				</div>
				<button onclick="cerrarToast(this.parentElement)" class="text-gray-300 hover:text-gray-500 transition-colors mt-0.5 shrink-0">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			{% endfor %}

			{% for msg in all_flashes.success_perfil %}
			<div class="toast-item pointer-events-auto flex items-start gap-3 bg-white border border-green-100 rounded-2xl shadow-xl px-4 py-3.5 opacity-0 translate-x-8 transition-all duration-500" data-type="success">
				<div class="w-9 h-9 rounded-xl bg-green-100 flex items-center justify-center shrink-0 mt-0.5">
					<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
					</svg>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-xs font-bold text-green-600 uppercase tracking-wider mb-0.5">¡Éxito!</p>
					<p class="text-sm font-medium text-gray-800 leading-snug">{{ msg }}</p>
				</div>
				<button onclick="cerrarToast(this.parentElement)" class="text-gray-300 hover:text-gray-500 transition-colors mt-0.5 shrink-0">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			{% endfor %}

			{% for msg in all_flashes.success_password %}
			<div class="toast-item pointer-events-auto flex items-start gap-3 bg-white border border-green-100 rounded-2xl shadow-xl px-4 py-3.5 opacity-0 translate-x-8 transition-all duration-500" data-type="success">
				<div class="w-9 h-9 rounded-xl bg-green-100 flex items-center justify-center shrink-0 mt-0.5">
					<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
					</svg>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-xs font-bold text-green-600 uppercase tracking-wider mb-0.5">¡Éxito!</p>
					<p class="text-sm font-medium text-gray-800 leading-snug">{{ msg }}</p>
				</div>
				<button onclick="cerrarToast(this.parentElement)" class="text-gray-300 hover:text-gray-500 transition-colors mt-0.5 shrink-0">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			{% endfor %}

			{% for msg in all_flashes.error %}
			<div class="toast-item pointer-events-auto flex items-start gap-3 bg-white border border-red-100 rounded-2xl shadow-xl px-4 py-3.5 opacity-0 translate-x-8 transition-all duration-500" data-type="error">
				<div class="w-9 h-9 rounded-xl bg-red-100 flex items-center justify-center shrink-0 mt-0.5">
					<svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
					</svg>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-xs font-bold text-red-500 uppercase tracking-wider mb-0.5">Atención</p>
					<p class="text-sm font-medium text-gray-800 leading-snug">{{ msg }}</p>
				</div>
				<button onclick="cerrarToast(this.parentElement)" class="text-gray-300 hover:text-gray-500 transition-colors mt-0.5 shrink-0">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			{% endfor %}

			{% for msg in all_flashes.error_perfil %}
			<div class="toast-item pointer-events-auto flex items-start gap-3 bg-white border border-red-100 rounded-2xl shadow-xl px-4 py-3.5 opacity-0 translate-x-8 transition-all duration-500" data-type="error">
				<div class="w-9 h-9 rounded-xl bg-red-100 flex items-center justify-center shrink-0 mt-0.5">
					<svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
					</svg>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-xs font-bold text-red-500 uppercase tracking-wider mb-0.5">Atención</p>
					<p class="text-sm font-medium text-gray-800 leading-snug">{{ msg }}</p>
				</div>
				<button onclick="cerrarToast(this.parentElement)" class="text-gray-300 hover:text-gray-500 transition-colors mt-0.5 shrink-0">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			{% endfor %}

			{% for msg in all_flashes.error_password %}
			<div class="toast-item pointer-events-auto flex items-start gap-3 bg-white border border-red-100 rounded-2xl shadow-xl px-4 py-3.5 opacity-0 translate-x-8 transition-all duration-500" data-type="error">
				<div class="w-9 h-9 rounded-xl bg-red-100 flex items-center justify-center shrink-0 mt-0.5">
					<svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
					</svg>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-xs font-bold text-red-500 uppercase tracking-wider mb-0.5">Atención</p>
					<p class="text-sm font-medium text-gray-800 leading-snug">{{ msg }}</p>
				</div>
				<button onclick="cerrarToast(this.parentElement)" class="text-gray-300 hover:text-gray-500 transition-colors mt-0.5 shrink-0">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
					</svg>
				</button>
			</div>
			{% endfor %}

		</div>
		{% endif %}

		{% block main_wrapper %}
		<main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full">
			{% block body %}{% endblock %}
		</main>
		{% endblock %}

		{% block site_footer %}
		<footer class="bg-white border-t border-gray-100 mt-auto">
			<div class="max-w-7xl mx-auto px-4 py-8 text-center text-sm text-gray-400 font-medium">
				&copy; {{ 'now'|date('Y') }} Venus Management System.
			</div>
		</footer>
		{% endblock %}

		<script>
			document.addEventListener('DOMContentLoaded', function () {
				const btn = document.getElementById('mobile-menu-btn');
				const menu = document.getElementById('mobile-menu');
				const iconMenu = document.getElementById('icon-menu');
				const iconClose = document.getElementById('icon-close');

				btn.addEventListener('click', function () {
					menu.classList.toggle('hidden');
					iconMenu.classList.toggle('hidden');
					iconClose.classList.toggle('hidden');
				});

				// ===== TOAST NOTIFICATIONS =====
				const toasts = document.querySelectorAll('.toast-item');
				toasts.forEach(function (toast, index) {
					// Slide-in con retardo escalonado
					setTimeout(function () {
						toast.classList.remove('opacity-0', 'translate-x-8');
					}, 100 + index * 120);

					// Auto-cerrar a los 4.5 segundos
					setTimeout(function () {
						cerrarToast(toast);
					}, 4500 + index * 120);
				});
			});

			function cerrarToast(el) {
				el.classList.add('opacity-0', 'translate-x-8');
				setTimeout(function () {
					el.remove();
					// Si no quedan toasts, eliminar el contenedor
					const container = document.getElementById('toast-container');
					if (container && container.querySelectorAll('.toast-item').length === 0) {
						container.remove();
					}
				}, 500);
			}
		</script>
	</body>
</html>

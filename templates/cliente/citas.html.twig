{% extends 'base.html.twig' %}

{% block title %}Mis Citas | Venus{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">

    <div class="bg-white rounded-3xl p-5 sm:p-8 shadow-sm border border-gray-100 mb-6 flex flex-wrap items-center gap-4">
        <div class="bg-pink-100 text-pink-600 w-16 h-16 sm:w-20 sm:h-20 rounded-full flex items-center justify-center text-3xl sm:text-4xl font-extrabold shadow-inner shrink-0">
            {{ app.user.nombre|first|upper }}
        </div>
        <div class="min-w-0">
            <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900">Hola, {{ app.user.nombre }}</h1>
            <p class="text-gray-500 font-medium mt-1 text-sm truncate">{{ app.user.email }}</p>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">

        <div class="px-5 py-4 sm:px-8 sm:py-6 border-b border-gray-100 bg-gray-50 flex flex-wrap justify-between items-center gap-3">
            <h2 class="text-lg sm:text-xl font-bold text-gray-900">Mis Próximas Citas</h2>
            <a href="{{ path('app_servicios') }}" class="text-sm font-bold text-white bg-gray-900 hover:bg-pink-500 px-4 py-2 sm:px-5 sm:py-2.5 rounded-xl shadow-md transition-all">
                Nueva Cita +
            </a>
        </div>

        <div class="p-4 sm:p-6">
            {% if app.user.citas is empty %}
                <div class="text-center py-10">
                    <div class="w-16 h-16 bg-pink-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">No tienes citas programadas</h3>
                    <p class="text-gray-500 mb-8 max-w-md mx-auto">¿Te apetece un cambio de look o un buen tratamiento? Anímate y reserva tu hueco.</p>
                    <a href="{{ path('app_servicios') }}" class="inline-block bg-pink-50 text-pink-600 font-bold px-8 py-3.5 rounded-xl hover:bg-pink-100 transition-colors border border-pink-100">
                        Ver Catálogo de Servicios
                    </a>
                </div>
            {% else %}
                <div class="space-y-3">
                    {% for cita in app.user.citas %}
                        <div class="border border-gray-100 rounded-2xl hover:border-pink-200 hover:shadow-md transition-all group overflow-hidden">

                            {# Cabecera de la tarjeta: fecha + estado #}
                            <div class="flex items-center justify-between px-4 py-3 bg-gray-50 group-hover:bg-pink-50 transition-colors border-b border-gray-100">
                                <div class="flex items-center gap-3">
                                    <div class="text-center">
                                        <span class="block text-xs font-bold text-gray-400 uppercase leading-none">{{ cita.fechaInicio|date('M') }}</span>
                                        <span class="block text-2xl font-extrabold text-gray-900 group-hover:text-pink-600 leading-tight">{{ cita.fechaInicio|date('d') }}</span>
                                    </div>
                                    <div class="w-px h-8 bg-gray-200"></div>
                                    <span class="text-sm font-semibold text-gray-500">{{ cita.fechaInicio|date('H:i') }} – {{ cita.fechaFin|date('H:i') }}</span>
                                </div>
                                {% if cita.estado != 'Cancelada' and cita.fechaInicio < date() %}
                                    <span class="font-bold uppercase text-xs px-2.5 py-1 rounded-full bg-gray-100 text-gray-600">Completada</span>
                                {% elseif cita.estado == 'Pendiente' %}
                                    <span class="font-bold uppercase text-xs px-2.5 py-1 rounded-full bg-yellow-100 text-yellow-700">Pendiente</span>
                                {% elseif cita.estado == 'Confirmada' %}
                                    <span class="font-bold uppercase text-xs px-2.5 py-1 rounded-full bg-green-100 text-green-700">Confirmada</span>
                                {% else %}
                                    <span class="font-bold uppercase text-xs px-2.5 py-1 rounded-full bg-red-100 text-red-700">Cancelada</span>
                                {% endif %}
                            </div>

                            {# Cuerpo: servicios + productos + acción #}
                            <div class="px-4 py-4">
                                <h4 class="text-base font-bold text-gray-900 leading-snug">
                                    {% for servicio in cita.servicios %}
                                        {{ servicio.nombre }}{% if not loop.last %} + {% endif %}
                                    {% else %}
                                        Cita General
                                    {% endfor %}
                                </h4>

                                {% if cita.productos|length > 0 %}
                                    <div class="mt-3 bg-pink-50 rounded-xl p-3 border border-pink-100">
                                        <p class="text-xs font-bold text-pink-600 uppercase tracking-wider mb-2">Productos del día</p>
                                        <ul class="space-y-1">
                                            {% for producto in cita.productos %}
                                                <li class="text-sm text-gray-700 font-medium flex justify-between">
                                                    <span>· {{ producto.nombre }}</span>
                                                    <span class="font-bold text-gray-900 shrink-0 ml-4">+{{ producto.precio }}€</span>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                {% endif %}

                                <div class="mt-4">
                                    {% if cita.estado != 'Cancelada' and cita.fechaInicio > date() %}
                                        <a href="{{ path('app_cita_cancelar', {'id': cita.id}) }}"
                                           onclick="return confirm('¿Estás seguro de que quieres cancelar esta cita? Esta acción no se puede deshacer.')"
                                           class="block w-full text-center text-red-500 hover:text-red-700 text-sm font-bold bg-red-50 hover:bg-red-100 px-4 py-2.5 rounded-xl transition-colors border border-red-100">
                                            Cancelar cita
                                        </a>
                                    {% else %}
                                        <a href="{{ path('app_cliente_cita_eliminar', {'id': cita.id}) }}"
                                           onclick="return confirm('¿Borrar este registro de tu historial?')"
                                           class="block w-full text-center text-gray-400 hover:text-red-500 text-sm font-semibold hover:bg-red-50 px-4 py-2.5 rounded-xl transition-colors">
                                            Eliminar del historial
                                        </a>
                                    {% endif %}
                                </div>
                            </div>

                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}

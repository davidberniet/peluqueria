{% extends 'base.html.twig' %}

{% block title %}Verificación 2FA | Venus
{% endblock %}

{% block body %}
	<div class="max-w-md mx-auto my-16">
		<div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
			<div class="bg-gray-900 p-8 text-center">
				<div class="w-16 h-16 bg-pink-500 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
					<span class="text-3xl">🔐</span>
				</div>
				<h1 class="text-2xl font-extrabold text-white">Verificación de 2 pasos</h1>
				<p class="text-gray-400 text-sm mt-2">Hemos enviado un código de 4 dígitos a tu correo electrónico por seguridad.</p>
			</div>

			<div
				class="p-8">
				{# Si el usuario pone el código mal, saldrá este error #}
				{% if authenticationError %}
					<div class="bg-red-50 text-red-600 p-4 rounded-xl text-sm font-bold mb-6 text-center border border-red-100">
						{{ authenticationError|trans(domain='SchebTwoFactorBundle') }}
					</div>
				{% endif %}

				<form action="{{ path('2fa_login_check') }}" method="post" class="space-y-6">
					<div>
						<label for="_auth_code" class="block text-sm font-bold text-gray-700 mb-2 text-center uppercase tracking-wider">Código de Autenticación</label>
						<input id="_auth_code" name="_auth_code" type="text" autocomplete="one-time-code" autofocus maxlength="4" class="w-full text-center text-3xl tracking-[0.5em] px-4 py-4 rounded-xl border-2 border-gray-200 focus:border-pink-500 focus:ring-0 outline-none font-extrabold text-gray-900 transition-colors" placeholder="••••"/>
					</div>

					<div class="flex items-center justify-center pt-2">
						<input type="checkbox" id="_trusted" name="_trusted" class="w-5 h-5 text-pink-600 bg-gray-100 border-gray-300 rounded focus:ring-pink-500 cursor-pointer" />
						<label for="_trusted" class="ml-2 text-sm font-medium text-gray-600 cursor-pointer select-none">No volver a pedir en este dispositivo</label>
					</div>

					<button type="submit" class="w-full bg-pink-600 hover:bg-pink-700 text-white font-bold py-4 rounded-xl shadow-md transition-colors text-lg transform hover:-translate-y-0.5">
						Verificar y Entrar
					</button>
				</form>

				<p class="text-center text-xs text-gray-400 mt-6">
					<a href="{{ path('app_logout') }}" class="hover:text-pink-600 underline transition-colors">Cancelar y volver al inicio</a>
				</p>
			</div>
		</div>
	</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Mi Perfil | Venus
{% endblock %}

{% block body %}
	<div
		class="max-w-4xl mx-auto my-10 px-4">

		{# ===== CABECERA ===== #}
		<div class="mb-8">
			<h1 class="text-3xl font-extrabold text-gray-900">Mi Perfil</h1>
			<p class="text-gray-500 mt-1">Gestiona tus datos y consulta tu historial de citas.</p>
		</div>

		{# ===== ESTADÍSTICAS ===== #}
		<div
			class="grid grid-cols-2 gap-3 sm:gap-4 mb-8">

			{# Tarjeta 1: Visitas #}
			<div class="bg-white rounded-2xl p-3 sm:p-5 shadow-sm border border-gray-100 flex items-center gap-3 sm:gap-4">
				<div class="bg-pink-100 p-3 sm:p-4 rounded-xl shrink-0">
					<span class="text-xl sm:text-2xl">✂️</span>
				</div>
				<div
					class="min-w-0">
					{# min-w-0 es vital para que el flexbox no se desborde #}
					<p class="text-[10px] sm:text-xs font-semibold text-gray-500 uppercase tracking-wider truncate">Visitas</p>
					<p class="text-xl sm:text-3xl font-extrabold text-gray-900 truncate">{{ totalCitas }}</p>
				</div>
			</div>

			{# Tarjeta 2: Total Gastado #}
			<div class="bg-white rounded-2xl p-3 sm:p-5 shadow-sm border border-gray-100 flex items-center gap-3 sm:gap-4">
				<div class="bg-green-100 p-3 sm:p-4 rounded-xl shrink-0">
					<span class="text-xl sm:text-2xl">💶</span>
				</div>
				<div class="min-w-0">
					<p class="text-[10px] sm:text-xs font-semibold text-gray-500 uppercase tracking-wider truncate">Gastado</p>
					<p class="text-xl sm:text-3xl font-extrabold text-gray-900 truncate">{{ totalGastado|number_format(2, ',', '.') }}€</p>
				</div>
			</div>

		</div>

		{# ===== DATOS PERSONALES ===== #}
		<div id="perfil" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
			<div class="flex items-center gap-3 p-6 border-b border-gray-100 bg-gray-50">
				<span class="text-2xl">👤</span>
				<div>
					<h2 class="text-xl font-extrabold text-gray-900">Mis Datos</h2>
					<p class="text-gray-400 text-sm">Actualiza tu información personal.</p>
				</div>
			</div>
			<div class="p-6">
				{% for msg in app.flashes('success_perfil') %}
					<div class="mb-4 bg-green-50 border border-green-200 text-green-700 text-base font-semibold px-4 py-3 rounded-xl">
						✅
						{{ msg }}
					</div>
				{% endfor %}

				{{ form_start(formPerfil, {'attr': {'class': 'flex flex-col gap-5'}}) }}

				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Nombre</label>
						{{ form_widget(formPerfil.nombre, {'attr': {
                            'class': 'w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400'
                        }}) }}
						{{ form_errors(formPerfil.nombre) }}
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Email</label>
						{{ form_widget(formPerfil.email, {'attr': {
                            'class': 'w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400'
                        }}) }}
						{{ form_errors(formPerfil.email) }}
					</div>
				</div>

				<div>
					<label class="block text-sm font-bold text-gray-600 mb-2">Teléfono</label>
					{{ form_widget(formPerfil.telefono, {'attr': {
                        'class': 'w-full md:w-1/2 border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400',
                        'placeholder': 'Ej: 612 345 678'
                    }}) }}
					{{ form_errors(formPerfil.telefono) }}
				</div>

				<div class="flex justify-end">
					<button type="submit" class="w-full md:w-auto bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-8 rounded-xl shadow-sm transition-colors text-base">
						Guardar cambios
					</button>
				</div>

				{{ form_end(formPerfil) }}
			</div>
		</div>

		{# ===== CAMBIAR CONTRASEÑA ===== #}
		<div id="password" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
			<div class="flex items-center gap-3 p-6 border-b border-gray-100 bg-gray-50">
				<span class="text-2xl">🔒</span>
				<div>
					<h2 class="text-xl font-extrabold text-gray-900">Cambiar Contraseña</h2>
					<p class="text-gray-400 text-sm">Por seguridad necesitamos tu contraseña actual.</p>
				</div>
			</div>
			<div class="p-6">
				{% for msg in app.flashes('success_password') %}
					<div class="mb-4 bg-green-50 border border-green-200 text-green-700 text-base font-semibold px-4 py-3 rounded-xl">
						✅
						{{ msg }}
					</div>
				{% endfor %}
				{% for msg in app.flashes('error_password') %}
					<div class="mb-4 bg-red-50 border border-red-200 text-red-700 text-base font-semibold px-4 py-3 rounded-xl">
						❌
						{{ msg }}
					</div>
				{% endfor %}

				{{ form_start(formPassword, {'attr': {'class': 'flex flex-col gap-5'}}) }}

				<div>
					<label class="block text-sm font-bold text-gray-600 mb-2">Contraseña actual</label>
					{{ form_widget(formPassword.passwordActual, {'attr': {
                        'class': 'w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400'
                    }}) }}
					{{ form_errors(formPassword.passwordActual) }}
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Nueva contraseña</label>
						{{ form_widget(formPassword.nuevaPassword.first, {'attr': {
                            'class': 'w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400'
                        }}) }}
						{{ form_errors(formPassword.nuevaPassword.first) }}
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-600 mb-2">Repetir nueva contraseña</label>
						{{ form_widget(formPassword.nuevaPassword.second, {'attr': {
                            'class': 'w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:outline-none focus:border-pink-400'
                        }}) }}
						{{ form_errors(formPassword.nuevaPassword.second) }}
					</div>
				</div>

				<div class="flex justify-end">
					<button type="submit" class="w-full md:w-auto bg-gray-900 hover:bg-pink-600 text-white font-extrabold py-3 px-8 rounded-xl shadow-sm transition-colors text-base">
						Cambiar contraseña
					</button>
				</div>

				{{ form_end(formPassword) }}
			</div>
		</div>

		{# ===== HISTORIAL DE CITAS ===== #}
		<div id="historial" class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
			<div class="flex items-center gap-3 p-6 border-b border-gray-100 bg-gray-50">
				<span class="text-2xl">📅</span>
				<div>
					<h2 class="text-xl font-extrabold text-gray-900">Mis Citas</h2>
					<p class="text-gray-400 text-sm">Tu historial completo de reservas.</p>
				</div>
			</div>

			{# --- Versión móvil: tarjetas --- #}
			<div class="block md:hidden divide-y divide-gray-100">
				{% for cita in citas %}
					<div class="p-5">
						<div class="flex justify-between items-start mb-3">
							<div>
								<p class="font-extrabold text-pink-600 text-lg">{{ cita.fechaInicio|date('H:i') }}</p>
								<p class="text-sm text-gray-500">{{ cita.fechaInicio|date('d/m/Y') }}</p>
							</div>
							<div class="text-right">
								{% set precio = 0 %}
								{% for servicio in cita.servicios %}
									{% set precio = precio + servicio.getPrecio() %}
								{% endfor %}
								<p class="font-extrabold text-gray-900 text-lg">{{ precio|number_format(2, ',', '.') }}€</p>
							</div>
						</div>

						<p class="text-base font-semibold text-gray-700 mb-3">
							{% for servicio in cita.servicios %}
								{{ servicio.nombre }}
								{% if not loop.last %}
									+
								{% endif %}
							{% endfor %}
						</p>

						<div class="flex justify-between items-center">
							{% if cita.estado != 'Cancelada' and cita.fechaInicio < date() %}
								<span class="px-3 py-1.5 bg-gray-100 text-gray-800 rounded-full text-sm font-bold">Completada</span>
							{% elseif cita.estado == 'Pendiente' %}
								<span class="px-3 py-1.5 bg-yellow-100 text-yellow-800 rounded-full text-sm font-bold">⏳ Pendiente</span>
							{% elseif cita.estado == 'Confirmada' %}
								<span class="px-3 py-1.5 bg-green-100 text-green-800 rounded-full text-sm font-bold">✅ Confirmada</span>
							{% else %}
								<span class="px-3 py-1.5 bg-red-100 text-red-800 rounded-full text-sm font-bold">❌ Cancelada</span>
							{% endif %}

							{% if cita.estado != 'Cancelada' and cita.fechaInicio > date() %}
								<a href="{{ path('app_cita_cancelar', {'id': cita.id}) }}" onclick="return confirm('¿Seguro que quieres cancelar esta cita?')" class="bg-red-500 hover:bg-red-600 text-white font-bold px-4 py-2 rounded-xl text-sm transition-colors">
									Cancelar
								</a>
							{% endif %}
						</div>
					</div>
				{% else %}
					<div class="p-8 text-center text-gray-500 text-base">
						Aún no tienes citas.
						<a href="{{ path('app_servicios') }}" class="text-pink-600 font-bold hover:underline">¡Reserva la primera!</a>
					</div>
				{% endfor %}
			</div>

			{# --- Versión escritorio: tabla --- #}
			<div class="hidden md:block overflow-x-auto">
				<table class="w-full text-left border-collapse">
					<thead>
						<tr class="text-gray-400 text-xs uppercase bg-white border-b border-gray-100">
							<th class="px-6 py-4 font-semibold">Fecha</th>
							<th class="px-6 py-4 font-semibold">Servicio</th>
							<th class="px-6 py-4 font-semibold">Precio</th>
							<th class="px-6 py-4 font-semibold">Estado</th>
							<th class="px-6 py-4 font-semibold text-right">Acción</th>
						</tr>
					</thead>
					<tbody class="text-sm text-gray-700">
						{% for cita in citas %}
							<tr class="border-b border-gray-50 hover:bg-gray-50 transition">
								<td class="px-6 py-4 font-bold text-pink-600 text-base">
									{{ cita.fechaInicio|date('d/m/Y') }}<br>
									<span class="text-gray-500 text-sm font-semibold">{{ cita.fechaInicio|date('H:i') }}</span>
								</td>
								<td class="px-6 py-4 font-semibold text-gray-800">
									{% for servicio in cita.servicios %}
										{{ servicio.nombre }}
										{% if not loop.last %}
											+
										{% endif %}
									{% endfor %}
								</td>
								<td class="px-6 py-4 font-extrabold text-gray-900 text-base">
									{% set precio = 0 %}
									{% for servicio in cita.servicios %}
										{% set precio = precio + servicio.getPrecio() %}
									{% endfor %}
									{{ precio|number_format(2, ',', '.') }}€
								</td>
								<td class="px-6 py-4">
									{% if cita.estado != 'Cancelada' and cita.fechaInicio < date() %}
										<span class="px-3 py-1.5 bg-gray-100 text-gray-800 rounded-full text-sm font-bold">
											Completada</span>
									{% elseif cita.estado == 'Pendiente' %}
										<span class="px-3 py-1.5 bg-yellow-100 text-yellow-800 rounded-full text-sm font-bold">⏳ Pendiente</span>
									{% elseif cita.estado == 'Confirmada' %}
										<span class="px-3 py-1.5 bg-green-100 text-green-800 rounded-full text-sm font-bold">✅ Confirmada</span>
									{% else %}
										<span class="px-3 py-1.5 bg-red-100 text-red-800 rounded-full text-sm font-bold">❌ Cancelada</span>
									{% endif %}
								</td>
								<td class="px-6 py-4 text-right">
									{% if cita.estado != 'Cancelada' and cita.fechaInicio > date() %}
										<a href="{{ path('app_cita_cancelar', {'id': cita.id}) }}" onclick="return confirm('¿Seguro que quieres cancelar esta cita?')" class="bg-red-50 hover:bg-red-500 hover:text-white text-red-600 font-bold px-4 py-2 rounded-xl border border-red-200 transition-colors text-sm">
											Cancelar
										</a>
									{% else %}
										<span class="text-gray-300 text-sm">—</span>
									{% endif %}
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="5" class="px-6 py-10 text-center text-gray-500 text-base">
									Aún no tienes citas.
									<a href="{{ path('app_servicios') }}" class="text-pink-600 font-bold hover:underline">¡Reserva la primera!</a>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>

	</div>
{% endblock %}
